<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Brands</h3></div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#brandModal" onclick="document.getElementById('brandId').value='';document.getElementById('brandName').value='';document.getElementById('brandDesc').value='';clearBrandLogo()"><i class="fas fa-plus me-1"></i>Add Brand</button>
    </div>
    <div class="card border-0 shadow-sm"><div class="card-body">
      <table class="table table-hover mb-0"><thead><tr><th>Name</th><th>Slug</th><th>Products</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="brandTable"></tbody></table>
    </div></div>
  </div>
</div>
<div class="modal fade" id="brandModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Add Brand</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <input type="hidden" id="brandId">
    <div class="mb-3"><label class="form-label">Name *</label><input type="text" class="form-control" id="brandName" required></div>
    <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" id="brandDesc" rows="2"></textarea></div>
    <div class="mb-3">
      <label class="form-label">Logo Image</label>
      <div class="d-flex gap-2 mb-2">
        <input type="file" class="form-control" id="brandLogoFile" accept="image/*" onchange="previewBrandLogo(this)">
        <input type="text" class="form-control" id="brandLogoUrl" placeholder="Or paste image URL" oninput="previewBrandLogoUrl(this.value)">
      </div>
      <div id="brandLogoPreview" class="text-center" style="display:none">
        <img src="" style="max-height:80px;border-radius:8px;border:1px solid #dee2e6;padding:4px">
        <button class="btn btn-sm btn-outline-danger ms-2" onclick="clearBrandLogo()"><i class="fas fa-times"></i></button>
      </div>
    </div>
  </div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveBrand()">Save</button></div>
</div></div></div>
<script>
async function loadBrands() {
  const data = await api('/brands');
  document.getElementById('brandTable').innerHTML = data.brands.map(b => `
  <tr>
    <td>
      ${b.logo ? `<img src="${b.logo}" style="height:30px;width:auto;border-radius:4px;margin-right:8px" onerror="this.style.display='none'"> ` : ''}
      <strong>${b.name}</strong>
    </td>
    <td>${b.slug}</td>
    <td>${b.product_count || 0}</td>
    <td><span class="badge bg-${b.is_active?'success':'secondary'}">${b.is_active?'Active':'Inactive'}</span></td>
    <td>
      <button class="btn btn-sm btn-outline-primary" onclick="editBrand(${b.id},'${b.name.replace(/'/g,"\\'")}','${(b.description||'').replace(/'/g,"\\'")}','${(b.logo||'').replace(/'/g,"\\'")}')"><i class="fas fa-edit"></i></button>
      <button class="btn btn-sm btn-outline-danger" onclick="deleteBrand(${b.id})"><i class="fas fa-trash"></i></button>
    </td>
  </tr>`).join('');
}
function editBrand(id,name,desc,logo){
  document.getElementById('brandId').value=id;
  document.getElementById('brandName').value=name;
  document.getElementById('brandDesc').value=desc;
  if(logo){
    document.getElementById('brandLogoUrl').value=logo;
    document.querySelector('#brandLogoPreview img').src=logo;
    document.querySelector('#brandLogoPreview').style.display='block';
  } else {
    clearBrandLogo();
  }
  new bootstrap.Modal(document.getElementById('brandModal')).show();
}
async function previewBrandLogo(input) {
  const file = input.files[0];
  if (!file) return;
  try {
    const url = await uploadFile(file, 'general');
    document.querySelector('#brandLogoPreview img').src = url;
    document.querySelector('#brandLogoPreview').style.display = 'block';
    document.getElementById('brandLogoUrl').value = url;
    document.getElementById('brandLogoFile').value = '';
  } catch(e) { showToast('Upload failed: ' + e.message, 'error'); }
}
function previewBrandLogoUrl(url) {
  if (!url) return;
  document.querySelector('#brandLogoPreview img').src = url;
  document.querySelector('#brandLogoPreview').style.display = 'block';
  document.getElementById('brandLogoFile').value = '';
}
function clearBrandLogo() {
  document.querySelector('#brandLogoPreview').style.display = 'none';
  document.getElementById('brandLogoFile').value = '';
  document.getElementById('brandLogoUrl').value = '';
}
async function saveBrand() {
  const id = document.getElementById('brandId').value;
  const body = { 
    name: document.getElementById('brandName').value, 
    description: document.getElementById('brandDesc').value,
    logo: document.getElementById('brandLogoUrl').value || null
  };
  try {
    if (id) await api(`/brands/${id}`, { method: 'PUT', body: JSON.stringify(body) });
    else await api('/brands', { method: 'POST', body: JSON.stringify(body) });
    bootstrap.Modal.getInstance(document.getElementById('brandModal')).hide();
    clearBrandLogo();
    showToast('Brand saved!'); loadBrands();
  } catch(e) { showToast(e.message, 'error'); }
}
async function deleteBrand(id) { if(!confirm('Delete?'))return; try{await api(`/brands/${id}`,{method:'DELETE'});showToast('Deleted');loadBrands();}catch(e){showToast(e.message,'error');} }
document.addEventListener('DOMContentLoaded', function() {
  loadBrands();
  document.getElementById('brandModal').addEventListener('hidden.bs.modal', clearBrandLogo);
});
</script>
<%- include('../partials/footer') %>
