<%- include('../partials/header') %>
<div class="d-flex">
  <nav class="admin-sidebar d-none d-lg-block">
    <div class="px-3 mb-4"><h5 class="text-white fw-bold"><i class="fas fa-fish me-2"></i>Admin</h5></div>
    <ul class="nav flex-column">
      <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li class="nav-item"><a class="nav-link active" href="/admin/users"><i class="fas fa-user-cog"></i> Users</a></li>
      <li class="nav-item mt-3"><a class="nav-link" href="/"><i class="fas fa-arrow-left"></i> Back</a></li>
    </ul>
  </nav>
  <div class="admin-content flex-grow-1">
    <h3 class="fw-bold mb-4">Users</h3>
    <div class="card border-0 shadow-sm"><div class="card-body">
      <table class="table table-hover mb-0"><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="usersTable"></tbody></table>
    </div></div>
  </div>
</div>
<script>
async function loadUsers(){try{const d=await api('/admin/users');document.getElementById('usersTable').innerHTML=d.users.map(u=>`<tr><td><strong>${u.name}</strong></td><td>${u.email||'-'}</td><td>${u.phone||'-'}</td>
  <td><select class="form-select form-select-sm" style="width:120px" onchange="updateUserRole(${u.id},this.value)">
    <option value="customer" ${u.role==='customer'?'selected':''}>Customer</option>
    <option value="staff" ${u.role==='staff'?'selected':''}>Staff</option>
    <option value="admin" ${u.role==='admin'?'selected':''}>Admin</option>
  </select></td>
  <td><span class="badge bg-${u.is_active?'success':'secondary'}">${u.is_active?'Active':'Inactive'}</span></td>
  <td><button class="btn btn-sm btn-outline-${u.is_active?'warning':'success'}" onclick="toggleUserStatus(${u.id},${!u.is_active})">${u.is_active?'Deactivate':'Activate'}</button></td></tr>`).join('');}catch(e){}}
async function updateUserRole(id,role){try{await api(`/admin/users/${id}/role`,{method:'PUT',body:JSON.stringify({role})});showToast('Role updated');}catch(e){showToast(e.message,'error');}}
async function toggleUserStatus(id,active){try{await api(`/admin/users/${id}/status`,{method:'PUT',body:JSON.stringify({is_active:active})});showToast('Status updated');loadUsers();}catch(e){showToast(e.message,'error');}}
document.addEventListener('DOMContentLoaded',loadUsers);
</script>
<%- include('../partials/footer') %>