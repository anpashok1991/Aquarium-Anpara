<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Pending Reviews</h3></div>
    <div id="reviewsList"></div>
  </div>
</div>
<script>
async function loadReviews(){try{const d=await api('/reviews/pending');if(!d.reviews.length){document.getElementById('reviewsList').innerHTML='<p class="text-muted">No pending reviews</p>';return;}document.getElementById('reviewsList').innerHTML=d.reviews.map(r=>{const imgs=r.images?JSON.parse(r.images):[];return `<div class="card border-0 shadow-sm mb-3 p-3"><div class="d-flex justify-content-between"><div><h6>${r.product_name||'Unknown Product'}</h6><div style="color:#ffc107">${'★'.repeat(r.rating)}${'☆'.repeat(5-r.rating)}</div><p class="mb-1"><strong>${r.customer_name}</strong>: ${r.title?'<em>'+r.title+'</em> ':''}${r.comment}</p>${imgs.length?imgs.map(i=>'<img src="'+i+'" style="height:50px;width:50px;object-fit:cover;border-radius:6px;margin:2px;border:1px solid #dee2e6" onerror="this.style.display=\'none\'" alt="review img">').join(''):''}</div><div class="d-flex gap-2"><button class="btn btn-sm btn-success" onclick="approveReview(${r.id})"><i class="fas fa-check"></i> Approve</button><button class="btn btn-sm btn-danger" onclick="deleteReview(${r.id})"><i class="fas fa-trash"></i></button></div></div></div>`;}).join('');}catch(e){}}
async function approveReview(id){try{await api(`/reviews/${id}/approve`,{method:'PUT'});showToast('Approved');loadReviews();}catch(e){showToast(e.message,'error');}}
async function deleteReview(id){if(!confirm('Delete?'))return;try{await api(`/reviews/${id}`,{method:'DELETE'});showToast('Deleted');loadReviews();}catch(e){showToast(e.message,'error');}}
document.addEventListener('DOMContentLoaded',loadReviews);
</script>
<%- include('../partials/footer') %>