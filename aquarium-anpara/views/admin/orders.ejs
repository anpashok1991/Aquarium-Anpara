<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Orders</h3></div>
    <div class="d-flex gap-2 mb-3 flex-wrap">
      <button class="btn btn-outline-primary btn-sm status-filter active" onclick="filterOrders('',this)">All</button>
      <button class="btn btn-outline-warning btn-sm status-filter" onclick="filterOrders('pending',this)">Pending</button>
      <button class="btn btn-outline-info btn-sm status-filter" onclick="filterOrders('confirmed',this)">Confirmed</button>
      <button class="btn btn-outline-primary btn-sm status-filter" onclick="filterOrders('processing',this)">Processing</button>
      <button class="btn btn-outline-secondary btn-sm status-filter" onclick="filterOrders('dispatched',this)">Dispatched</button>
      <button class="btn btn-outline-success btn-sm status-filter" onclick="filterOrders('delivered',this)">Delivered</button>
      <button class="btn btn-outline-danger btn-sm status-filter" onclick="filterOrders('cancelled',this)">Cancelled</button>
    </div>
    <div class="card border-0 shadow-sm"><div class="card-body">
      <div class="table-responsive"><table class="table table-hover mb-0">
        <thead><tr><th>Order #</th><th>Customer</th><th>Phone</th><th>Total</th><th>Payment</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody id="ordersTable"></tbody>
      </table></div>
    </div></div>
  </div>
</div>
<script>
let currentStatus = '';
function filterOrders(s,btn) { currentStatus = s; document.querySelectorAll('.status-filter').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); loadOrders(); }
async function loadOrders() {
  const params = currentStatus ? `?status=${currentStatus}` : '';
  try {
    const data = await api(`/orders${params}`);
    document.getElementById('ordersTable').innerHTML = data.orders.map(o => `
      <tr>
        <td><strong>${o.order_number}</strong></td><td>${o.customer_name}</td><td>${o.customer_phone}</td>
        <td>₹${o.total.toLocaleString()}</td>
        <td><span class="badge bg-${o.payment_status==='paid'?'success':'warning'}">${o.payment_method}</span></td>
        <td><select class="form-select form-select-sm" style="width:130px" onchange="updateOrderStatus(${o.id}, this.value)">
          ${['pending','confirmed','processing','dispatched','delivered','cancelled'].map(s=>`<option value="${s}" ${o.order_status===s?'selected':''}>${s}</option>`).join('')}
        </select></td>
        <td>${new Date(o.created_at).toLocaleDateString()}</td>
        <td><button class="btn btn-sm btn-outline-primary" onclick="viewOrder(${o.id})"><i class="fas fa-eye"></i></button>
        <button class="btn btn-sm btn-outline-secondary" onclick="viewTracking(${o.id})"><i class="fas fa-history"></i></button>
        ${o.order_status === 'delivered' || o.order_status === 'completed' ? `<a href="/invoice/${o.order_number}" target="_blank" class="btn btn-sm btn-outline-info"><i class="fas fa-receipt"></i></a>` : ''}
        <button class="btn btn-sm btn-outline-success" onclick="sendOrderWhatsApp({order_number:'${o.order_number}',customer_name:'${o.customer_name}',customer_phone:'${o.customer_phone}',total:${o.total}})"><i class="fab fa-whatsapp"></i></button></td>
      </tr>`).join('');
  } catch(e) { console.error(e); }
}
async function updateOrderStatus(id, status) {
  try { await api(`/orders/${id}/status`, { method:'PUT', body: JSON.stringify({ order_status: status }) }); showToast('Status updated'); } catch(e) { showToast(e.message, 'error'); }
}
async function viewOrder(id) {
  try {
    const data = await api(`/orders/${id}`);
    const o = data.order;
    let items = '';
    if (o.items) items = o.items.map(i => `<tr><td>${i.product_name}</td><td>${i.quantity}</td><td>₹${i.price}</td><td>₹${i.total}</td></tr>`).join('');
    const modal = document.createElement('div');
    modal.className = 'modal fade'; modal.innerHTML = `<div class="modal-dialog modal-lg"><div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">Order #${o.order_number}</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="row mb-3"><div class="col-6"><strong>Customer:</strong> ${o.customer_name}<br><strong>Phone:</strong> ${o.customer_phone}<br><strong>Email:</strong> ${o.customer_email||'-'}</div>
        <div class="col-6"><strong>Address:</strong> ${o.shipping_address}, ${o.shipping_city}, ${o.shipping_state} - ${o.shipping_pincode}<br><strong>Payment:</strong> ${o.payment_method.toUpperCase()}<br><strong>Status:</strong> ${o.order_status}</div></div>
        <table class="table table-sm"><thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead><tbody>${items}</tbody></table>
        <div class="text-end"><strong>Subtotal: ₹${o.subtotal.toLocaleString()}</strong><br><strong>Discount: -₹${o.discount}</strong><br><strong>Shipping: ₹${o.shipping_charge}</strong><br><h5>Total: ₹${o.total.toLocaleString()}</h5>
        ${o.order_status === 'delivered' || o.order_status === 'completed' ? `<a href="/invoice/${o.order_number}" target="_blank" class="btn btn-outline-primary btn-sm mt-2"><i class="fas fa-receipt me-1"></i>View Invoice</a>` : ''}</div>
      </div></div></div>`;
    document.body.appendChild(modal);
    const bsModal = new bootstrap.Modal(modal);
    bsModal.show();
    modal.addEventListener('hidden.bs.modal', () => modal.remove());
  } catch(e) { showToast(e.message, 'error'); }
}
async function viewTracking(id) {
  try {
    const data = await api(`/orders/${id}/tracking`);
    const tracking = data.tracking || [];
    const statusIcon = { pending:'fa-clock', confirmed:'fa-check-circle', processing:'fa-spinner', dispatched:'fa-truck', delivered:'fa-home', cancelled:'fa-times-circle' };
    const list = tracking.map((t, i) => {
      const isLast = i === tracking.length - 1;
      return `<div class="d-flex mb-2">
        <div class="me-2 text-center" style="width:28px;flex-shrink:0">
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:28px;height:28px;background:${isLast ? 'var(--primary,#0d6efd)' : '#e9ecef'};color:${isLast ? '#fff' : '#6c757d'}">
            <i class="fas ${statusIcon[t.status] || 'fa-circle'} fa-xs"></i>
          </div>
          ${!isLast ? '<div style="width:2px;height:30px;background:#e9ecef;margin:2px auto"></div>' : ''}
        </div>
        <div style="padding-top:2px">
          <div class="${isLast ? 'fw-bold' : ''} small">${t.description || t.status}</div>
          <small class="text-muted" style="font-size:11px">${new Date(t.created_at).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</small>
        </div>
      </div>`;
    }).join('');
    const modal = document.createElement('div');
    modal.className = 'modal fade'; modal.innerHTML = `<div class="modal-dialog"><div class="modal-content">
      <div class="modal-header"><h5 class="modal-title"><i class="fas fa-history me-2"></i>Tracking Timeline</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">${list || '<p class="text-muted small">No tracking entries yet.</p>'}</div>
    </div></div>`;
    document.body.appendChild(modal);
    const bsModal = new bootstrap.Modal(modal);
    bsModal.show();
    modal.addEventListener('hidden.bs.modal', () => modal.remove());
  } catch(e) { showToast(e.message, 'error'); }
}
document.addEventListener('DOMContentLoaded', loadOrders);
</script>
<%- include('../partials/footer') %>
