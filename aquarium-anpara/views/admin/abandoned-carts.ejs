<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center">
        <button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button>
        <div>
          <h3 class="fw-bold mb-0">Abandoned Carts</h3>
          <small class="text-muted">Users who added products but didn't place an order</small>
        </div>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-primary btn-sm" onclick="loadAbandonedCarts()"><i class="fas fa-sync me-1"></i>Refresh</button>
        <button class="btn btn-success btn-sm" onclick="exportAbandonedCSV()"><i class="fas fa-file-excel me-1"></i>Export</button>
      </div>
    </div>

    <div class="alert alert-info">
      <i class="fas fa-lightbulb me-1"></i> Contact these users to offer discounts and convert them into customers.
    </div>

    <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
      <div class="input-group" style="max-width:320px">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" class="form-control" id="abandonedSearch" placeholder="Search name, phone, email..." oninput="renderAbandoned()">
      </div>
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="showDismissed" onchange="renderAbandoned()">
        <label class="form-check-label" for="showDismissed">Show contacted</label>
      </div>
      <button class="btn btn-outline-secondary btn-sm" onclick="restoreAll()" id="restoreAllBtn" style="display:none"><i class="fas fa-undo me-1"></i>Restore all</button>
    </div>

    <div id="abandonedStats" class="row g-3 mb-4"></div>
    <div id="abandonedList"></div>
    <div id="abandonedEmpty" class="text-center py-5" style="display:none">
      <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
      <h5>No abandoned carts</h5>
      <p class="text-muted">All users who added items have completed their orders.</p>
    </div>
  </div>
</div>

<script>
let allCarts = [];

function getDismissed() {
  try { return JSON.parse(localStorage.getItem('abandoned_dismissed') || '[]'); } catch(e) { return []; }
}

function setDismissed(ids) {
  localStorage.setItem('abandoned_dismissed', JSON.stringify(ids));
}

function dismissCart(id) {
  const ids = getDismissed();
  if (!ids.includes(id)) ids.push(id);
  setDismissed(ids);
  renderAbandoned();
}

function restoreCart(id) {
  let ids = getDismissed();
  ids = ids.filter(i => i !== id);
  setDismissed(ids);
  renderAbandoned();
}

function restoreAll() {
  setDismissed([]);
  renderAbandoned();
}

function cartId(c) {
  return c.user_id ? 'user_' + c.user_id : 'session_' + c.session_id;
}

function renderAbandoned() {
  const list = document.getElementById('abandonedList');
  const empty = document.getElementById('abandonedEmpty');
  const stats = document.getElementById('abandonedStats');
  const search = document.getElementById('abandonedSearch').value.toLowerCase().trim();
  const showDismissed = document.getElementById('showDismissed').checked;
  const dismissed = getDismissed();

  let filtered = allCarts.filter(c => {
    if (!showDismissed && dismissed.includes(cartId(c))) return false;
    if (!search) return true;
    return (c.customer_name || '').toLowerCase().includes(search) ||
           (c.customer_phone || '').toLowerCase().includes(search) ||
           (c.customer_email || '').toLowerCase().includes(search);
  });

  if (!allCarts.length) {
    list.innerHTML = '';
    stats.innerHTML = '';
    empty.style.display = '';
    return;
  }
  empty.style.display = 'none';

  const totalAbandoned = allCarts.length;
  const totalValue = allCarts.reduce((s, c) => s + c.total, 0);
  const withPhone = allCarts.filter(c => c.customer_phone).length;
  const pendingCount = allCarts.filter(c => !dismissed.includes(cartId(c))).length;

  stats.innerHTML = `
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><h3 class="text-warning">${totalAbandoned}</h3><p class="mb-0 text-muted">Total</p></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><h3 class="text-primary">₹${totalValue.toLocaleString()}</h3><p class="mb-0 text-muted">Potential Revenue</p></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><h3 class="text-success">${withPhone}/${totalAbandoned}</h3><p class="mb-0 text-muted">Contactable</p></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body text-center"><h3 class="text-info">${pendingCount}</h3><p class="mb-0 text-muted">Pending</p></div></div></div>`;

  document.getElementById('showDismissed').checked = showDismissed;
  document.getElementById('restoreAllBtn').style.display = dismissed.length ? '' : 'none';

  if (!filtered.length) {
    list.innerHTML = '<div class="alert alert-secondary text-center">' + (search ? 'No carts match your search.' : 'All carts have been contacted.') + '</div>';
    return;
  }

  list.innerHTML = filtered.map(c => {
    const id = cartId(c);
    const isDismissed = dismissed.includes(id);
    return `
      <div class="card border-0 shadow-sm mb-3 ${isDismissed ? 'opacity-50' : ''}">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <h5 class="fw-bold mb-1">${escHtml(c.customer_name)} ${isDismissed ? '<span class="badge bg-secondary"><i class="fas fa-check me-1"></i>Contacted</span>' : ''}</h5>
              ${c.customer_phone ? '<a href="tel:' + c.customer_phone + '" class="text-decoration-none"><i class="fas fa-phone me-1"></i>' + c.customer_phone + '</a>' : '<span class="text-muted"><i class="fas fa-user-slash me-1"></i>No phone (guest)</span>'}
              ${c.customer_email ? ' | <small>' + c.customer_email + '</small>' : ''}
            </div>
            <div class="d-flex align-items-start gap-2">
              <div class="text-end">
                <h4 class="text-primary fw-bold mb-1">₹${c.total.toLocaleString()}</h4>
                <small class="text-muted">${c.items.length} item${c.items.length > 1 ? 's' : ''}</small>
              </div>
              ${isDismissed
                ? `<button class="btn btn-sm btn-outline-secondary" onclick="restoreCart('${id}')" title="Mark not contacted"><i class="fas fa-undo"></i></button>`
                : `<button class="btn btn-sm btn-outline-danger" onclick="dismissCart('${id}')" title="Mark contacted / ignore"><i class="fas fa-times"></i></button>`
              }
            </div>
          </div>
          <div class="small text-muted mb-2">Last active: ${new Date(c.last_active).toLocaleString()}</div>
          <div class="d-flex flex-wrap gap-1">
            ${c.items.map(i => `<span class="badge bg-light text-dark border">${escHtml(i.product_name)} x${i.quantity} - ₹${(i.price * i.quantity).toLocaleString()}</span>`).join('')}
          </div>
        </div>
      </div>`;
  }).join('');
}

async function loadAbandonedCarts() {
  try {
    const d = await api('/reports/abandoned-carts');
    allCarts = d.carts || [];
    renderAbandoned();
  } catch(e) {
    document.getElementById('abandonedList').innerHTML = '<div class="alert alert-danger">Failed to load: ' + e.message + '</div>';
  }
}

function escHtml(s) { return String(s || '').replace(/[&<>"']/g, function(m) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]; }); }

function exportAbandonedCSV() {
  const rows = [['Customer Name','Phone','Email','Items','Total','Last Active','Contacted']];
  const dismissed = getDismissed();
  allCarts.forEach(c => {
    const id = cartId(c);
    rows.push([
      c.customer_name || 'Guest',
      c.customer_phone || '',
      c.customer_email || '',
      (c.items || []).map(i => i.product_name + ' x' + i.quantity).join('; '),
      c.total,
      new Date(c.last_active).toLocaleString(),
      dismissed.includes(id) ? 'Yes' : 'No'
    ]);
  });
  const csv = rows.map(r => r.map(v => typeof v === 'string' && (v.includes(',')||v.includes('"')||v.includes('\n')) ? '"'+v.replace(/"/g,'""')+'"' : v).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'abandoned-carts.csv'; document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

document.addEventListener('DOMContentLoaded', loadAbandonedCarts);
</script>
<%- include('../partials/footer') %>