<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Customers</h3></div>
    <div class="d-flex gap-2 mb-3">
      <input type="text" class="form-control" id="searchCust" placeholder="Search customers..." style="max-width:300px" onkeyup="loadCustomers()">
      <select class="form-select" id="filterStatus" style="max-width:180px" onchange="loadCustomers()">
        <option value="all">All Customers</option>
        <option value="active">Active Only</option>
        <option value="inactive">Inactive Only</option>
      </select>
    </div>
    <div class="card border-0 shadow-sm"><div class="card-body">
      <table class="table table-hover mb-0"><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>City</th><th>Orders</th><th>Total Spent</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="custTable"></tbody></table>
    </div></div>
  </div>
</div>
<script>
async function loadCustomers() {
  const search = document.getElementById('searchCust').value;
  const status = document.getElementById('filterStatus').value;
  const params = new URLSearchParams();
  if (search) params.set('search', search);
  if (status === 'active') params.set('is_active', '1');
  else if (status === 'inactive') params.set('is_active', '0');
  try {
    const data = await api(`/customers?${params}`);
    document.getElementById('custTable').innerHTML = data.customers.map(c => `
      <tr class="${c.is_active === 0 ? 'table-danger' : ''}">
        <td><strong>${c.name}</strong></td>
        <td>${c.email||'-'}</td>
        <td>${c.phone||'-'}</td>
        <td>${c.city||'-'}</td>
        <td>${c.total_orders}</td>
        <td>₹${(c.total_spent||0).toLocaleString()}</td>
        <td>${c.is_active === 0 ? '<span class="badge bg-secondary">Inactive</span>' : '<span class="badge bg-success">Active</span>'}</td>
        <td>
          <button class="btn btn-sm ${c.is_active === 0 ? 'btn-success' : 'btn-warning'}" onclick="toggleStatus(${c.id}, ${c.is_active === 0 ? 1 : 0})">
            <i class="fas ${c.is_active === 0 ? 'fa-check' : 'fa-ban'}"></i> ${c.is_active === 0 ? 'Activate' : 'Deactivate'}
          </button>
          <button class="btn btn-sm btn-danger" onclick="deleteCustomer(${c.id}, '${c.name.replace(/'/g, "\\'")}')">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      </tr>`).join('');
  } catch(e) { console.error(e); }
}

async function toggleStatus(id, newStatus) {
  try {
    await api(`/customers/${id}/status`, { method: 'PUT', body: { is_active: newStatus } });
    loadCustomers();
  } catch(e) { alert('Failed to update status'); }
}

async function deleteCustomer(id, name) {
  if (!confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) return;
  try {
    await api(`/customers/${id}`, { method: 'DELETE' });
    loadCustomers();
  } catch(e) { alert('Failed to delete customer'); }
}

document.addEventListener('DOMContentLoaded', loadCustomers);
</script>
<%- include('../partials/footer') %>