<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Categories</h3></div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#catModal" onclick="resetCatForm()"><i class="fas fa-plus me-1"></i>Add Category</button>
    </div>
    <div class="card border-0 shadow-sm"><div class="card-body">
      <table class="table table-hover mb-0"><thead><tr><th>Image</th><th>Icon</th><th>Name</th><th>Slug</th><th>Parent</th><th>Products</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="catTable"></tbody></table>
    </div></div>
  </div>
</div>
<div class="modal fade" id="catModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title" id="catModalTitle">Add Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <input type="hidden" id="catId">
    <div class="mb-3">
      <label class="form-label">Name *</label>
      <input type="text" class="form-control" id="catName" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Parent Category</label>
      <select class="form-select" id="catParent"><option value="">None (Top Level)</option></select>
    </div>
    <div class="mb-3">
      <label class="form-label">Description</label>
      <textarea class="form-control" id="catDesc" rows="2"></textarea>
    </div>
    <div class="mb-3">
      <label class="form-label">Icon</label>
      <select class="form-select" id="catIcon">
        <option value="">None</option>
        <option value="fa-fish">🐟 Fish</option>
        <option value="fa-dog">🐕 Dog</option>
        <option value="fa-cat">🐱 Cat</option>
        <option value="fa-dove">🐦 Bird</option>
        <option value="fa-bug">🐛 Insect</option>
        <option value="fa-frog">🐸 Reptile</option>
        <option value="fa-horse">🐴 Horse</option>
        <option value="fa-paw">🐾 Pet</option>
        <option value="fa-bone">🦴 Bone</option>
        <option value="fa-leaf">🌿 Plant</option>
        <option value="fa-seedling">🌱 Seedling</option>
        <option value="fa-star">⭐ Decoration</option>
        <option value="fa-pills">💊 Medicine</option>
        <option value="fa-gear">⚙️ Equipment</option>
        <option value="fa-tag">🏷️ Tag</option>
        <option value="fa-bowl-food">🥣 Food</option>
        <option value="fa-water">💧 Water</option>
        <option value="fa-apple-alt">🍎 Organic</option>
      </select>
      <div id="iconPreview" class="mt-2 small text-muted" style="display:none">Selected: <i class="fas"></i></div>
    </div>
    <div class="mb-3">
      <label class="form-label">Image</label>
      <div class="d-flex align-items-center gap-3">
        <input type="file" class="form-control" id="catImageInput" accept="image/*">
        <button class="btn btn-outline-secondary btn-sm" type="button" onclick="document.getElementById('catImageInput').value='';document.getElementById('catImagePreview').style.display='none';document.getElementById('catImageUrl').value=''">Clear</button>
      </div>
      <input type="hidden" id="catImageUrl">
      <div id="catImagePreview" class="mt-2" style="display:none">
        <img src="" alt="Preview" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--gray-light)">
      </div>
      <small class="text-muted">Upload an image or paste a URL directly below</small>
      <input type="url" class="form-control mt-1" id="catImageUrlDirect" placeholder="Or paste image URL here" oninput="previewDirectUrl(this.value)">
    </div>
    <div class="form-check"><input class="form-check-input" type="checkbox" id="catActive" checked><label class="form-check-label">Active</label></div>
    <div class="form-check mt-2"><input class="form-check-input" type="checkbox" id="catLive"><label class="form-check-label">Live Animal Category <small class="text-muted">(shows breeds instead of brands)</small></label></div>
  </div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveCategory()">Save</button></div>
</div></div></div>
<script>
const CAT_ICONS = ['fa-fish','fa-dog','fa-cat','fa-dove','fa-bug','fa-frog','fa-horse','fa-paw','fa-bone','fa-leaf','fa-seedling','fa-star','fa-pills','fa-gear','fa-tag','fa-bowl-food','fa-water','fa-apple-alt'];

function resetCatForm() {
  document.getElementById('catId').value = '';
  document.getElementById('catName').value = '';
  document.getElementById('catDesc').value = '';
  document.getElementById('catActive').checked = true;
  document.getElementById('catLive').checked = false;
  document.getElementById('catIcon').value = '';
  document.getElementById('catImageUrl').value = '';
  document.getElementById('catImageUrlDirect').value = '';
  document.getElementById('catImageInput').value = '';
  document.getElementById('catImagePreview').style.display = 'none';
  document.getElementById('catModalTitle').textContent = 'Add Category';
  document.getElementById('iconPreview').style.display = 'none';
}

document.getElementById('catIcon').addEventListener('change', function() {
  const preview = document.getElementById('iconPreview');
  if (this.value) {
    preview.querySelector('i').className = 'fas ' + this.value;
    preview.style.display = '';
  } else {
    preview.style.display = 'none';
  }
});

function previewDirectUrl(url) {
  const preview = document.getElementById('catImagePreview');
  const img = preview.querySelector('img');
  if (url) {
    img.src = url;
    preview.style.display = 'block';
  } else {
    preview.style.display = 'none';
  }
}

async function loadCategories() {
  const data = await api('/categories');
  const parentSel = document.getElementById('catParent');
  parentSel.innerHTML = '<option value="">None (Top Level)</option>';
  data.flat.forEach(c => parentSel.add(new Option(c.name, c.id)));
  document.getElementById('catTable').innerHTML = data.flat.map(c => `
    <tr>
      <td>
        ${c.image ? `<img src="${c.image}" alt="${c.name}" style="width:50px;height:50px;object-fit:cover;border-radius:8px;" onerror="this.parentElement.innerHTML='<span class=\\'text-muted\\' style=\\'font-size:0.8rem\\'>No img</span>'">`
          : '<span class="text-muted" style="font-size:0.8rem">No img</span>'}
      </td>
      <td class="text-center">${c.icon ? '<i class="fas ' + c.icon + ' fa-lg"></i>' : '<span class="text-muted">-</span>'}</td>
      <td><strong>${c.name}</strong>${c.is_live ? ' <span class="badge bg-info"><i class="fas fa-paw"></i> Live</span>' : ''}</td>
      <td>${c.slug}</td>
      <td>${c.parent_id ? data.flat.find(x=>x.id===c.parent_id)?.name || '-' : '-'}</td>
      <td>${c.product_count || 0}</td>
      <td><span class="badge bg-${c.is_active?'success':'secondary'}">${c.is_active?'Active':'Inactive'}</span></td>
      <td>
        <button class="btn btn-sm btn-outline-primary" onclick="editCategory(${c.id})"><i class="fas fa-edit"></i></button>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteCategory(${c.id})"><i class="fas fa-trash"></i></button>
      </td>
    </tr>`).join('');
}

function editCategory(id) {
  api('/categories').then(d => {
    const c = d.flat.find(x => x.id === id);
    if (!c) return;
    document.getElementById('catId').value = c.id;
    document.getElementById('catName').value = c.name;
    document.getElementById('catDesc').value = c.description || '';
    document.getElementById('catParent').value = c.parent_id || '';
    document.getElementById('catIcon').value = c.icon || '';
    document.getElementById('catActive').checked = !!c.is_active;
    document.getElementById('catLive').checked = !!c.is_live;
    document.getElementById('catImageUrl').value = c.image || '';
    document.getElementById('catImageUrlDirect').value = c.image || '';
    const preview = document.getElementById('catImagePreview');
    if (c.image) {
      preview.querySelector('img').src = c.image;
      preview.style.display = 'block';
    } else {
      preview.style.display = 'none';
    }
    const iconPrev = document.getElementById('iconPreview');
    if (c.icon) {
      iconPrev.querySelector('i').className = 'fas ' + c.icon;
      iconPrev.style.display = '';
    } else {
      iconPrev.style.display = 'none';
    }
    document.getElementById('catModalTitle').textContent = 'Edit Category';
    new bootstrap.Modal(document.getElementById('catModal')).show();
  });
}

async function saveCategory() {
  const id = document.getElementById('catId').value;
  const fileInput = document.getElementById('catImageInput');
  let imageUrl = document.getElementById('catImageUrlDirect').value || document.getElementById('catImageUrl').value || null;

  if (fileInput.files.length > 0) {
    try {
      imageUrl = await uploadFile(fileInput.files[0], 'categories');
    } catch (e) {
      showToast('Image upload failed: ' + e.message, 'error');
      return;
    }
  }

  const body = {
    name: document.getElementById('catName').value,
    description: document.getElementById('catDesc').value,
    icon: document.getElementById('catIcon').value || null,
    image: imageUrl,
    parent_id: parseInt(document.getElementById('catParent').value) || null,
    is_active: document.getElementById('catActive').checked,
    is_live: document.getElementById('catLive').checked ? 1 : 0
  };
  try {
    if (id) await api(`/categories/${id}`, { method: 'PUT', body: JSON.stringify(body) });
    else await api('/categories', { method: 'POST', body: JSON.stringify(body) });
    bootstrap.Modal.getInstance(document.getElementById('catModal')).hide();
    showToast('Category saved!');
    loadCategories();
  } catch (e) { showToast(e.message, 'error'); }
}

async function deleteCategory(id) {
  if (!confirm('Delete this category?')) return;
  try {
    await api(`/categories/${id}`, { method: 'DELETE' });
    showToast('Deleted');
    loadCategories();
  } catch (e) { showToast(e.message, 'error'); }
}

document.addEventListener('DOMContentLoaded', loadCategories);
</script>
<%- include('../partials/footer') %>