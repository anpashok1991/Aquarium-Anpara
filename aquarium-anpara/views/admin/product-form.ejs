<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0" id="formTitle">Add Product</h3></div>
    <form id="productForm" class="card border-0 shadow-sm p-4">
      <div class="row g-3">
        <div class="col-md-8"><label class="form-label">Product Name *</label><input type="text" class="form-control" id="name" required></div>
        <div class="col-md-4"><label class="form-label">SKU</label><input type="text" class="form-control" id="sku"></div>
        <div class="col-12"><label class="form-label">Short Description</label><input type="text" class="form-control" id="shortDesc"></div>
        <div class="col-12"><label class="form-label">Full Description</label><textarea class="form-control" id="description" rows="4"></textarea></div>
        <div class="col-md-3"><label class="form-label">Price *</label><input type="number" class="form-control" id="price" step="0.01" required></div>
        <div class="col-md-3"><label class="form-label">Discount Price</label><input type="number" class="form-control" id="discountPrice" step="0.01" oninput="if(this.value&&parseFloat(this.value)>parseFloat(document.getElementById('price').value)){this.value=document.getElementById('price').value}"></div>
        <div class="col-md-3"><label class="form-label">Cost Price</label><input type="number" class="form-control" id="costPrice" step="0.01"></div>
        <div class="col-md-2"><label class="form-label">GST (%)</label><input type="number" class="form-control" id="gstPercent" step="0.01" min="0" max="100" placeholder="0"></div>
        <div class="col-md-2"><label class="form-label">HSN Code *</label><input type="text" class="form-control" id="hsnCode" placeholder="e.g. 9503.00" required></div>
        <div class="col-md-3"><label class="form-label">Stock *</label><input type="number" class="form-control" id="stock" value="0" required></div>
        <div class="col-md-4"><label class="form-label">Category</label><select class="form-select" id="category" onchange="toggleBreedBrand()"></select></div>
        <div class="col-md-4" id="brandField"><label class="form-label">Brand</label><select class="form-select" id="brand"></select></div>
        <div class="col-md-4" id="breedField" style="display:none"><label class="form-label">Breed</label><select class="form-select" id="breed"></select></div>
        <div class="col-md-4">
          <label class="form-label">Barcode</label>
          <div class="input-group">
            <input type="text" class="form-control" id="barcode" placeholder="Scan or generate">
            <button class="btn btn-outline-primary" type="button" onclick="generateBarcode()" title="Generate unique barcode"><i class="fas fa-qrcode me-1"></i>Generate</button>
          </div>
        </div>
        <div class="col-md-4"><label class="form-label">Low Stock Threshold</label><input type="number" class="form-control" id="lowStock" value="5"></div>
        <div class="col-md-4"><label class="form-label">Weight (kg)</label><input type="number" class="form-control" id="weight" step="0.01" value="0"></div>
        <div class="col-md-4"><label class="form-label">Product Video URL</label><input type="url" class="form-control" id="videoUrl" placeholder="https://www.youtube.com/embed/..."><small class="text-muted">YouTube embed URL or any direct video URL</small></div>
        <div class="col-12"><label class="form-label">Product Images <small class="text-muted">(first image is primary, drag to reorder)</small></label>
          <div class="d-flex flex-wrap gap-2 mb-2" id="imageList"></div>
          <div class="d-flex gap-2">
            <input type="file" class="form-control" id="imageFile" accept="image/*" multiple>
            <input type="url" class="form-control" id="imageUrlInput" placeholder="Or enter image URL" style="max-width:300px">
            <button type="button" class="btn btn-outline-secondary" onclick="addImageUrl()"><i class="fas fa-plus"></i></button>
          </div>
        </div>
        <div class="col-12">
          <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="isFeatured"><label class="form-check-label">Featured</label></div>
          <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="isBestSeller"><label class="form-check-label">Best Seller</label></div>
          <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="isNewArrival"><label class="form-check-label">New Arrival</label></div>
          <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="isActive" checked><label class="form-check-label">Active</label></div>
        </div>
        <div class="col-12"><label class="form-label">Meta Title</label><input type="text" class="form-control" id="metaTitle"></div>
        <div class="col-12"><label class="form-label">Meta Description</label><textarea class="form-control" id="metaDesc" rows="2"></textarea></div>
      </div>
      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-1"></i>Save Product</button>
        <a href="/admin/products" class="btn btn-outline-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
<script>
const product = <%- JSON.stringify(product || null) %>;
let pendingImages = [];
let deletedImageIds = [];

async function loadForm() {
  const [cData, bData, breedData] = await Promise.all([api('/categories'), api('/brands'), api('/breeds')]);
  const catSel = document.getElementById('category');
  const brandSel = document.getElementById('brand');
  const breedSel = document.getElementById('breed');
  window._catLiveMap = {};
  cData.flat.forEach(c => {
    catSel.add(new Option(c.name, c.id));
    window._catLiveMap[c.id] = c.is_live ? true : false;
  });
  bData.brands.forEach(b => brandSel.add(new Option(b.name, b.id)));
  breedData.breeds.forEach(b => {
    const opt = new Option(b.name, b.id);
    opt.dataset.cat = b.category_id || '';
    breedSel.add(opt);
  });
  window._breedMap = {};
  breedData.breeds.forEach(b => {
    if (!window._breedMap[b.category_id]) window._breedMap[b.category_id] = {};
    window._breedMap[b.category_id][b.name.toLowerCase()] = b.id;
  });
  if (product) {
    document.getElementById('formTitle').textContent = 'Edit Product';
    document.getElementById('name').value = product.name || '';
    document.getElementById('sku').value = product.sku || '';
    document.getElementById('shortDesc').value = product.short_description || '';
    document.getElementById('description').value = product.description || '';
    document.getElementById('price').value = product.price || '';
    document.getElementById('discountPrice').value = product.discount_price || '';
    document.getElementById('costPrice').value = product.cost_price || '';
    document.getElementById('gstPercent').value = product.gst_percent || '';
    document.getElementById('hsnCode').value = product.hsn_code || '';
    document.getElementById('stock').value = product.stock_quantity || 0;
    document.getElementById('barcode').value = product.barcode || '';
    document.getElementById('lowStock').value = product.low_stock_threshold || 5;
    document.getElementById('weight').value = product.weight || 0;
    document.getElementById('videoUrl').value = product.video_url || '';
    if (product.category_id) catSel.value = product.category_id;
    if (product.brand_id) brandSel.value = product.brand_id;
    if (product.breed_id) breedSel.value = product.breed_id;
    document.getElementById('isFeatured').checked = !!product.is_featured;
    document.getElementById('isBestSeller').checked = !!product.is_best_seller;
    document.getElementById('isNewArrival').checked = !!product.is_new_arrival;
    document.getElementById('isActive').checked = product.is_active !== 0;
    document.getElementById('metaTitle').value = product.meta_title || '';
    document.getElementById('metaDesc').value = product.meta_description || '';
    if (product.product_images && product.product_images.length) {
      product.product_images.forEach(img => addImagePreview(img.image_url, true));
    }
  }
  toggleBreedBrand();
}

function autoSelectBreed() {
  const catId = document.getElementById('category').value;
  if (!window._catLiveMap[catId]) return;
  const name = document.getElementById('name').value.trim().toLowerCase();
  const catBreeds = window._breedMap[catId];
  if (!catBreeds) return;
  const match = catBreeds[name];
  document.getElementById('breed').value = match || '';
}

function toggleBreedBrand() {
  const catId = document.getElementById('category').value;
  const isLive = window._catLiveMap[catId];
  document.getElementById('brandField').style.display = isLive ? 'none' : '';
  document.getElementById('breedField').style.display = isLive ? '' : 'none';
  document.querySelectorAll('#breed option').forEach(o => {
    if (!o.value) return;
    o.style.display = Number(o.dataset.cat) === Number(catId) ? '' : 'none';
  });
  autoSelectBreed();
}

function addImagePreview(url, existing = false) {
  const list = document.getElementById('imageList');
  const div = document.createElement('div');
  div.className = 'position-relative';
  div.style.cssText = 'width:100px;height:100px;cursor:grab';
  div.draggable = true;
  div.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;border:2px solid #dee2e6" onerror="this.parentElement.remove()">
    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0" style="border-radius:50%;padding:2px 6px;font-size:10px;transform:translate(25%,-25%)" onclick="this.parentElement.remove()">&times;</button>
    <div class="position-absolute bottom-0 start-0 end-0 text-center" style="font-size:10px;background:rgba(0,0,0,0.5);color:#fff;border-radius:0 0 8px 8px">${existing ? 'saved' : 'new'}</div>`;
  div.addEventListener('dragstart', e => { e.dataTransfer.setData('text/plain', Array.from(list.children).indexOf(div)); });
  div.addEventListener('dragover', e => { e.preventDefault(); const after = Array.from(list.children).find(c => c !== div && c.getBoundingClientRect().left > e.clientX); list.insertBefore(div, after || null); });
  list.appendChild(div);
}

document.getElementById('imageFile').addEventListener('change', async function() {
  for (const file of this.files) {
    const url = await uploadFile(file, 'products');
    pendingImages.push(url);
    addImagePreview(url);
  }
  this.value = '';
});

function addImageUrl() {
  const input = document.getElementById('imageUrlInput');
  if (!input.value.trim()) return;
  addImagePreview(input.value.trim());
  input.value = '';
}

document.getElementById('name').addEventListener('input', autoSelectBreed);
document.getElementById('category').addEventListener('change', autoSelectBreed);

function generateBarcode() {
  const ts = Date.now().toString().slice(-8);
  const rand = Math.floor(Math.random() * 100000).toString().padStart(5, '0');
  const barcode = ts + rand;
  document.getElementById('barcode').value = barcode;
  showToast('Barcode generated: ' + barcode);
}

document.getElementById('productForm').addEventListener('submit', async(e) => {
  e.preventDefault();
  const price = parseFloat(document.getElementById('price').value);
  const discPrice = parseFloat(document.getElementById('discountPrice').value) || 0;
  if (discPrice > price) { showToast('Discount price cannot be greater than price', 'error'); return; }
  if (!document.getElementById('hsnCode').value.trim()) { showToast('HSN Code is required', 'error'); document.getElementById('hsnCode').focus(); return; }
  const imageItems = document.querySelectorAll('#imageList img');
  const images = [];
  imageItems.forEach(img => images.push({ url: img.src }));
  const body = {
    name: document.getElementById('name').value,
    description: document.getElementById('description').value,
    short_description: document.getElementById('shortDesc').value,
    sku: document.getElementById('sku').value,
    barcode: document.getElementById('barcode').value,
    price,
    discount_price: discPrice,
    cost_price: parseFloat(document.getElementById('costPrice').value) || 0,
    gst_percent: parseFloat(document.getElementById('gstPercent').value) || 0,
    hsn_code: document.getElementById('hsnCode').value,
    category_id: parseInt(document.getElementById('category').value) || null,
    brand_id: parseInt(document.getElementById('brand').value) || null,
    breed_id: parseInt(document.getElementById('breed').value) || null,
    stock_quantity: parseInt(document.getElementById('stock').value),
    low_stock_threshold: parseInt(document.getElementById('lowStock').value),
    weight: parseFloat(document.getElementById('weight').value) || 0,
    is_featured: document.getElementById('isFeatured').checked,
    is_best_seller: document.getElementById('isBestSeller').checked,
    is_new_arrival: document.getElementById('isNewArrival').checked,
    is_active: document.getElementById('isActive').checked,
    meta_title: document.getElementById('metaTitle').value,
    meta_description: document.getElementById('metaDesc').value,
    video_url: document.getElementById('videoUrl').value || null,
    images
  };
  try {
    if (product) { await api(`/products/${product.id}`, { method: 'PUT', body: JSON.stringify(body) }); }
    else { await api('/products', { method: 'POST', body: JSON.stringify(body) }); }
    showToast('Product saved!');
    window.location.href = '/admin/products';
  } catch(e) { showToast(e.message, 'error'); }
});
document.addEventListener('DOMContentLoaded', loadForm);
</script>
<%- include('../partials/footer') %>