<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Settings</h3></div>
    <div class="card border-0 shadow-sm p-4">
      <div class="row g-3">
        <div class="col-md-6"><label class="form-label">Shop Name</label><input type="text" class="form-control" id="shopName"></div>
        <div class="col-md-6"><label class="form-label">Shop Phone</label><input type="tel" class="form-control" id="shopPhone" maxlength="10" pattern="[0-9]{10}" inputmode="numeric" onkeypress="return event.charCode >= 48 && event.charCode <= 57"></div>
        <div class="col-md-6"><label class="form-label">Shop Email</label><input type="email" class="form-control" id="shopEmail"></div>
        <div class="col-md-6"><label class="form-label">WhatsApp Number</label><input type="tel" class="form-control" id="whatsappNumber" maxlength="10" pattern="[0-9]{10}" inputmode="numeric" onkeypress="return event.charCode >= 48 && event.charCode <= 57"></div>
        <div class="col-12"><label class="form-label">Shop Address</label><textarea class="form-control" id="shopAddress" rows="2"></textarea></div>
        <div class="col-md-6"><label class="form-label">Shop Logo</label>
          <div class="d-flex align-items-center gap-2">
            <input type="file" class="form-control" id="shopLogoFile" accept="image/*" onchange="previewLogoFile(this)">
            <button class="btn btn-outline-danger btn-sm" type="button" onclick="removeLogo()" title="Remove logo"><i class="fas fa-times"></i></button>
          </div>
          <div class="d-flex align-items-center gap-3 mt-2" id="logoPreviewWrap" style="display:none">
            <img src="" id="logoPreviewImg" style="height:40px;width:auto;max-width:160px;object-fit:contain;border-radius:4px;border:1px solid var(--gray-light)">
            <button class="btn btn-outline-secondary btn-sm" type="button" onclick="document.getElementById('shopLogoFile').click()">Change</button>
          </div>
          <input type="hidden" id="shopLogo"></div>
        <div class="col-md-6"><label class="form-label">Free Delivery Min Order (₹)</label><input type="number" class="form-control" id="minOrder"></div>
        <div class="col-md-6"><label class="form-label">Delivery Charge (₹)</label><input type="number" class="form-control" id="deliveryCharge"></div>
        <div class="col-12"><hr><h5 class="fw-bold">Email / SMTP Settings</h5></div>
        <div class="col-md-6"><label class="form-label">SMTP Host</label><input type="text" class="form-control" id="smtpHost" placeholder="smtp.gmail.com"></div>
        <div class="col-md-3"><label class="form-label">SMTP Port</label><input type="number" class="form-control" id="smtpPort" placeholder="587"></div>
        <div class="col-md-3"><label class="form-label">SMTP Secure</label><select class="form-select" id="smtpSecure"><option value="false">No (Port 587)</option><option value="true">Yes (Port 465)</option></select></div>
        <div class="col-md-6"><label class="form-label">SMTP Username</label><input type="text" class="form-control" id="smtpUser" placeholder="your@email.com"></div>
        <div class="col-md-6"><label class="form-label">SMTP Password</label><input type="password" class="form-control" id="smtpPass" placeholder="App password"></div>
        <div class="col-12"><button class="btn btn-outline-primary btn-sm" onclick="testEmail()"><i class="fas fa-paper-plane me-1"></i>Test Email</button></div>
        <div class="col-12"><hr><h5 class="fw-bold">Payment Settings</h5></div>
        <div class="col-12"><label class="form-label">Enabled Payment Methods</label>
          <div class="d-flex flex-wrap gap-3 mt-1">
            <div class="form-check"><input class="form-check-input" type="checkbox" id="payCod" value="cod" checked><label class="form-check-label">Cash on Delivery</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" id="payUpi" value="upi"><label class="form-check-label">UPI Payment</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" id="payBank" value="bank_transfer"><label class="form-check-label">Bank Transfer</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" id="payScan" value="scan_pay"><label class="form-check-label">Scan & Pay</label></div>
          </div>
        </div>
        <div class="col-12" id="scannerConfig" style="display:none">
          <label class="form-label mt-2 fw-bold">Payment Scanners</label>
          <p class="text-muted small">Configure up to 2 UPI QR scanners visible when customers choose Scan & Pay.</p>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label small">Your UPI ID (VPA)</label>
              <input type="text" class="form-control form-control-sm" id="upiId" placeholder="e.g. merchant@paytm or merchant@upi">
              <div class="form-text small">When set, a dynamic QR with the exact order amount will also be shown for auto-fill.</div>
            </div>
          </div>
          <% for (let i = 1; i <= 2; i++) { %>
          <div class="row g-2 mb-2 align-items-end">
            <div class="col-md-4">
              <label class="form-label small">Scanner <%= i %> Name</label>
              <input type="text" class="form-control form-control-sm" id="scanner<%= i %>Name" placeholder="e.g. Google Pay">
            </div>
            <div class="col-md-6">
              <label class="form-label small">QR Code Image</label>
              <div class="d-flex align-items-center gap-2">
                <input type="file" class="form-control form-control-sm" id="scanner<%= i %>File" accept="image/*">
                <button class="btn btn-outline-danger btn-sm" type="button" onclick="removeScannerQr(<%= i %>)" title="Remove"><i class="fas fa-times"></i></button>
              </div>
              <div id="scanner<%= i %>Preview" class="mt-1" style="display:none">
                <img src="" style="height:60px;width:auto;object-fit:contain;border:1px solid var(--gray-light);border-radius:4px">
              </div>
              <input type="hidden" id="scanner<%= i %>Qr">
            </div>
          </div>
          <% } %>
        </div>
        <div class="col-12"><hr><h5 class="fw-bold">Homepage Promotions</h5>
          <p class="text-muted small">Configure up to 2 promotional spaces on the homepage. Leave disabled to show nothing.</p>
          <% for (let i = 1; i <= 2; i++) { %>
          <div class="card border mb-3">
            <div class="card-header d-flex align-items-center justify-content-between bg-light">
              <strong>Promotion <%= i %></strong>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="promo<%= i %>Enabled">
                <label class="form-check-label" for="promo<%= i %>Enabled">Enabled</label>
              </div>
            </div>
            <div class="card-body">
              <div class="row g-2">
                <div class="col-md-4">
                  <label class="form-label small">Display Type</label>
                  <select class="form-select form-select-sm" id="promo<%= i %>Type">
                    <option value="image">Full Image Banner</option>
                    <option value="text">Text with Icon</option>
                    <option value="both">Image + Text</option>
                    <option value="carousel">Carousel</option>
                  </select>
                </div>
                <div class="col-md-8 promo-image-group" id="promo<%= i %>ImageGroup">
                  <label class="form-label small">Image</label>
                  <div class="d-flex align-items-center gap-2">
                    <input type="file" class="form-control form-control-sm" id="promo<%= i %>File" accept="image/*">
                    <button class="btn btn-outline-danger btn-sm" type="button" onclick="removePromoImage(<%= i %>)" title="Remove"><i class="fas fa-times"></i></button>
                  </div>
                  <div id="promo<%= i %>ImagePreview" class="mt-1" style="display:none">
                    <img src="" style="height:50px;width:auto;max-width:200px;object-fit:contain;border-radius:4px;border:1px solid var(--gray-light)">
                  </div>
                  <input type="hidden" id="promo<%= i %>Image">
                </div>
                <div class="col-md-6 promo-text-group" id="promo<%= i %>TextGroup">
                  <label class="form-label small">Icon (.png)</label>
                  <div class="d-flex align-items-center gap-2">
                    <input type="file" class="form-control form-control-sm" id="promo<%= i %>IconFile" accept="image/png">
                    <button class="btn btn-outline-danger btn-sm" type="button" onclick="removePromoIcon(<%= i %>)" title="Remove"><i class="fas fa-times"></i></button>
                  </div>
                  <div id="promo<%= i %>IconPreview" class="mt-1" style="display:none">
                    <img src="" style="height:30px;width:auto;object-fit:contain">
                  </div>
                  <input type="hidden" id="promo<%= i %>Icon">
                </div>
                <div class="col-md-6 promo-text-group">
                  <label class="form-label small">Heading</label>
                  <input type="text" class="form-control form-control-sm" id="promo<%= i %>Heading" placeholder="Special Offer!">
                </div>
                <div class="col-12 promo-text-group">
                  <label class="form-label small">Text</label>
                  <textarea class="form-control form-control-sm" id="promo<%= i %>Text" rows="2" placeholder="Description of the promotion"></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label small">Link URL</label>
                  <input type="text" class="form-control form-control-sm" id="promo<%= i %>Link" placeholder="/shop">
                </div>
                <div class="col-md-6">
                  <label class="form-label small">Link Text</label>
                  <input type="text" class="form-control form-control-sm" id="promo<%= i %>LinkText" placeholder="Shop Now">
                </div>
              </div>
            </div>
          </div>
          <% } %>
        </div>
        <div class="col-12"><hr><h5 class="fw-bold">SEO Settings</h5></div>
        <div class="col-md-6"><label class="form-label">Google Search Console Verification Code</label><input type="text" class="form-control" id="googleVerification" placeholder="e.g. ABCDEF1234567890"></div>
        <div class="col-md-6"><label class="form-label">Google Analytics Measurement ID</label><input type="text" class="form-control" id="gaId" placeholder="e.g. G-XXXXXXXXXX"></div>
        <div class="col-md-6"><label class="form-label">Facebook Pixel ID</label><input type="text" class="form-control" id="fbPixel" placeholder="e.g. 1234567890"></div>
        <div class="col-12"><label class="form-label">Default Meta Keywords</label><textarea class="form-control" id="metaKeywords" rows="2" placeholder="aquarium shop, pet store, aquarium fish, pet supplies"></textarea></div>
      </div>
      <button class="btn btn-primary btn-lg mt-4" onclick="saveSettings()"><i class="fas fa-save me-1"></i>Save Settings</button>
      <hr class="mt-5"><div class="mt-4 p-4 rounded" style="border:2px solid #dc3545;background:#fff5f5">
        <h5 class="fw-bold text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Danger Zone</h5>
        <p class="text-muted small">Reset the database to a clean state for testing. Preserves admin user account and settings.</p>
        <button class="btn btn-outline-danger" onclick="startReset()"><i class="fas fa-trash-alt me-1"></i>Reset Database</button>
      </div>
    </div>
  </div>
</div>

<!-- Reset Database Modal (multi-step) -->
<div class="modal fade" id="resetModal" data-bs-backdrop="static" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0"><h5 class="modal-title fw-bold text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Reset Database</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body text-center" id="resetStepBody">
        <!-- Step 1: Warning -->
        <div id="resetStep1">
          <div class="mb-3"><i class="fas fa-trash-alt text-danger" style="font-size:3rem"></i></div>
          <h5 class="fw-bold">This will permanently delete ALL data!</h5>
          <p class="text-muted small">Every product, order, customer, category, brand, review, banner, coupon, and gallery image will be removed.</p>
          <p class="text-muted small mb-0">Admin account and shop settings will be preserved.</p>
          <button class="btn btn-danger btn-lg mt-3" onclick="resetStep(2)"><i class="fas fa-arrow-right me-1"></i>I Understand, Continue</button>
        </div>
        <!-- Step 2: Type DELETE -->
        <div id="resetStep2" style="display:none">
          <div class="mb-3"><i class="fas fa-keyboard text-warning" style="font-size:3rem"></i></div>
          <h5 class="fw-bold">Type DELETE to confirm</h5>
          <p class="text-muted small">Enter the word exactly as shown below to proceed.</p>
          <div class="d-flex justify-content-center mb-3">
            <div style="background:var(--dark,#212529);color:#fff;padding:8px 24px;border-radius:8px;font-family:monospace;font-size:1.3rem;letter-spacing:4px;font-weight:bold">DELETE</div>
          </div>
          <input type="text" class="form-control text-center form-control-lg" id="resetDeleteWord" placeholder="Type DELETE" maxlength="6" style="max-width:200px;margin:0 auto;text-transform:uppercase" oninput="checkDeleteWord(this.value)">
          <button class="btn btn-danger btn-lg mt-3" id="resetStep2Btn" disabled onclick="resetStep(3)">Continue</button>
        </div>
        <!-- Step 3: Captcha -->
        <div id="resetStep3" style="display:none">
          <div class="mb-3"><i class="fas fa-shield-alt text-primary" style="font-size:3rem"></i></div>
          <h5 class="fw-bold">Security Verification</h5>
          <p class="text-muted small">Solve this to confirm you're not a robot.</p>
          <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
            <span id="captchaNum1" class="fw-bold fs-3">0</span>
            <span class="fw-bold fs-4">+</span>
            <span id="captchaNum2" class="fw-bold fs-3">0</span>
            <span class="fw-bold fs-4">=</span>
            <input type="number" class="form-control form-control-lg text-center" id="captchaAnswer" placeholder="?" style="max-width:100px" oninput="checkCaptcha(this.value)">
          </div>
          <button class="btn btn-danger btn-lg mt-3" id="resetStep3Btn" disabled onclick="executeReset()"><i class="fas fa-trash-alt me-1"></i>Delete Everything</button>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function showLogoPreview(url) {
  const wrap = document.getElementById('logoPreviewWrap');
  const img = document.getElementById('logoPreviewImg');
  if (url) {
    img.src = url;
    wrap.style.display = 'flex';
    document.getElementById('shopLogo').value = url;
  } else {
    wrap.style.display = 'none';
    document.getElementById('shopLogo').value = '';
  }
}
function previewLogoFile(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => showLogoPreview(e.target.result);
    reader.readAsDataURL(input.files[0]);
  }
}
function removeLogo() {
  document.getElementById('shopLogoFile').value = '';
  showLogoPreview('');
}
function getPaymentMethods() {
  const methods = [];
  document.querySelectorAll('[id^="pay"]:checked').forEach(cb => methods.push(cb.value));
  return methods;
}
function setPaymentMethods(arr) {
  document.querySelectorAll('[id^="pay"]').forEach(cb => cb.checked = arr.includes(cb.value));
  document.getElementById('scannerConfig').style.display = arr.includes('scan_pay') ? '' : 'none';
}
function removeScannerQr(i) {
  document.getElementById('scanner'+i+'Qr').value='';
  document.getElementById('scanner'+i+'File').value='';
  document.getElementById('scanner'+i+'Preview').style.display='none';
}
function setupScannerUpload(i) {
  document.getElementById('scanner'+i+'File').addEventListener('change', async function() {
    if (this.files.length) {
      const url = await uploadFile(this.files[0], 'settings');
      document.getElementById('scanner'+i+'Qr').value = url;
      const p = document.getElementById('scanner'+i+'Preview');
      p.style.display='flex'; p.querySelector('img').src=url;
    }
  });
}
function loadPromo(i, d) {
  const en = document.getElementById('promo'+i+'Enabled');
  const tp = document.getElementById('promo'+i+'Type');
  const img = document.getElementById('promo'+i+'Image');
  const icon = document.getElementById('promo'+i+'Icon');
  const hd = document.getElementById('promo'+i+'Heading');
  const tx = document.getElementById('promo'+i+'Text');
  const lk = document.getElementById('promo'+i+'Link');
  const lt = document.getElementById('promo'+i+'LinkText');
  en.checked = d && d.enabled;
  tp.value = (d && d.type) || 'image';
  img.value = (d && d.image_url) || '';
  icon.value = (d && d.icon_url) || '';
  hd.value = (d && d.heading) || '';
  tx.value = (d && d.text) || '';
  lk.value = (d && d.link_url) || '';
  lt.value = (d && d.link_text) || '';
  if (img.value) { const p = document.querySelector('#promo'+i+'ImagePreview'); p.style.display='flex'; p.querySelector('img').src=img.value; }
  if (icon.value) { const p = document.querySelector('#promo'+i+'IconPreview'); p.style.display='flex'; p.querySelector('img').src=icon.value; }
  togglePromoType(i);
}
function togglePromoType(i) {
  const t = document.getElementById('promo'+i+'Type').value;
  document.getElementById('promo'+i+'ImageGroup').style.display = (t==='text')?'none':'';
  document.querySelectorAll('#promo'+i+'TextGroup').forEach(el => el.style.display = (t==='image')?'none':'');
}
function removePromoImage(i) {
  document.getElementById('promo'+i+'Image').value='';
  document.getElementById('promo'+i+'File').value='';
  document.querySelector('#promo'+i+'ImagePreview').style.display='none';
}
function removePromoIcon(i) {
  document.getElementById('promo'+i+'Icon').value='';
  document.getElementById('promo'+i+'IconFile').value='';
  document.querySelector('#promo'+i+'IconPreview').style.display='none';
}
function setupPromoFileUpload(i) {
  document.getElementById('promo'+i+'File').addEventListener('change', async function() {
    if (this.files.length) {
      const url = await uploadFile(this.files[0], 'settings');
      document.getElementById('promo'+i+'Image').value = url;
      const p = document.querySelector('#promo'+i+'ImagePreview');
      p.style.display='flex'; p.querySelector('img').src=url;
    }
  });
  document.getElementById('promo'+i+'IconFile').addEventListener('change', async function() {
    if (this.files.length) {
      const url = await uploadFile(this.files[0], 'settings');
      document.getElementById('promo'+i+'Icon').value = url;
      const p = document.querySelector('#promo'+i+'IconPreview');
      p.style.display='flex'; p.querySelector('img').src=url;
    }
  });
  document.getElementById('promo'+i+'Type').addEventListener('change', () => togglePromoType(i));
}
async function loadSettings(){try{const d=await api('/settings');const s=d.settings;document.getElementById('shopName').value=s.shop_name||'';document.getElementById('shopPhone').value=s.shop_phone||'';document.getElementById('shopEmail').value=s.shop_email||'';document.getElementById('whatsappNumber').value=s.whatsapp_number||'';document.getElementById('shopAddress').value=s.shop_address||'';document.getElementById('shopLogo').value=s.shop_logo||'';document.getElementById('minOrder').value=s.min_order_free_delivery||'500';document.getElementById('deliveryCharge').value=s.delivery_charge||'50';document.getElementById('smtpHost').value=s.smtp_host||'';document.getElementById('smtpPort').value=s.smtp_port||'587';document.getElementById('smtpSecure').value=s.smtp_secure||'false';document.getElementById('smtpUser').value=s.smtp_user||'';document.getElementById('smtpPass').value=s.smtp_pass||'';document.getElementById('googleVerification').value=s.google_verification||'';document.getElementById('gaId').value=s.ga_id||'';document.getElementById('fbPixel').value=s.fb_pixel||'';document.getElementById('metaKeywords').value=s.meta_keywords||'';document.getElementById('upiId').value=s.upi_id||'';try{setPaymentMethods(JSON.parse(s.payment_methods||'["cod"]'));}catch(e){setPaymentMethods(['cod']);}if(s.shop_logo){showLogoPreview(s.shop_logo);}for(let i=1;i<=2;i++){try{const p=JSON.parse(s['promotion_'+i]||'{}');loadPromo(i,p);}catch(e){loadPromo(i,{});}}for(let i=1;i<=2;i++){try{const qr=JSON.parse(s['scanner_'+i]||'{}');document.getElementById('scanner'+i+'Name').value=qr.name||'';document.getElementById('scanner'+i+'Qr').value=qr.qr||'';if(qr.qr){const p=document.getElementById('scanner'+i+'Preview');p.style.display='flex';p.querySelector('img').src=qr.qr;}}catch(e){}}}catch(e){}}
async function testEmail() {
  const email = document.getElementById('shopEmail').value;
  if (!email) { showToast('Please enter a Shop Email first', 'error'); return; }
  try {
    await api('/settings/test-email', { method: 'POST', body: JSON.stringify({ email, smtp_host: document.getElementById('smtpHost').value, smtp_port: document.getElementById('smtpPort').value, smtp_secure: document.getElementById('smtpSecure').value, smtp_user: document.getElementById('smtpUser').value, smtp_pass: document.getElementById('smtpPass').value }) });
    showToast('Test email sent! Check your inbox.');
  } catch(e) { showToast(e.message, 'error'); }
}
function getPromoData(i) {
  return {
    enabled: document.getElementById('promo'+i+'Enabled').checked,
    type: document.getElementById('promo'+i+'Type').value,
    image_url: document.getElementById('promo'+i+'Image').value,
    icon_url: document.getElementById('promo'+i+'Icon').value,
    heading: document.getElementById('promo'+i+'Heading').value,
    text: document.getElementById('promo'+i+'Text').value,
    link_url: document.getElementById('promo'+i+'Link').value,
    link_text: document.getElementById('promo'+i+'LinkText').value
  };
}
async function saveSettings(){try{const fileInput=document.getElementById('shopLogoFile');let logoUrl=document.getElementById('shopLogo').value;if(fileInput.files.length>0){logoUrl=await uploadFile(fileInput.files[0],'settings');}const body={shop_name:document.getElementById('shopName').value,shop_phone:document.getElementById('shopPhone').value,shop_email:document.getElementById('shopEmail').value,whatsapp_number:document.getElementById('whatsappNumber').value,shop_address:document.getElementById('shopAddress').value,shop_logo:logoUrl,min_order_free_delivery:document.getElementById('minOrder').value,delivery_charge:document.getElementById('deliveryCharge').value,smtp_host:document.getElementById('smtpHost').value,smtp_port:document.getElementById('smtpPort').value,smtp_secure:document.getElementById('smtpSecure').value,smtp_user:document.getElementById('smtpUser').value,smtp_pass:document.getElementById('smtpPass').value,payment_methods:JSON.stringify(getPaymentMethods()),upi_id:document.getElementById('upiId').value,google_verification:document.getElementById('googleVerification').value,ga_id:document.getElementById('gaId').value,fb_pixel:document.getElementById('fbPixel').value,meta_keywords:document.getElementById('metaKeywords').value};for(let i=1;i<=2;i++){body['promotion_'+i]=JSON.stringify(getPromoData(i));body['scanner_'+i]=JSON.stringify({name:document.getElementById('scanner'+i+'Name').value,qr:document.getElementById('scanner'+i+'Qr').value});}await api('/settings',{method:'PUT',body:JSON.stringify(body)});showToast('Settings saved!');}catch(e){showToast(e.message,'error');}}
document.addEventListener('DOMContentLoaded',()=>{loadSettings();document.querySelectorAll('[id^="pay"]').forEach(cb=>cb.addEventListener('change',()=>setPaymentMethods(getPaymentMethods())));for(let i=1;i<=2;i++){setupPromoFileUpload(i);setupScannerUpload(i);}});

// Reset Database multi-step
let resetCaptchaAnswer = 0;
function startReset() {
  // Reset to step 1
  document.getElementById('resetStep1').style.display = '';
  document.getElementById('resetStep2').style.display = 'none';
  document.getElementById('resetStep3').style.display = 'none';
  document.getElementById('resetDeleteWord').value = '';
  document.getElementById('resetStep2Btn').disabled = true;
  document.getElementById('captchaAnswer').value = '';
  document.getElementById('resetStep3Btn').disabled = true;
  new bootstrap.Modal(document.getElementById('resetModal')).show();
}
function resetStep(n) {
  document.querySelectorAll('#resetStepBody > div').forEach(d => d.style.display = 'none');
  document.getElementById('resetStep' + n).style.display = '';
  if (n === 3) {
    const n1 = Math.floor(Math.random() * 10) + 1;
    const n2 = Math.floor(Math.random() * 10) + 1;
    resetCaptchaAnswer = n1 + n2;
    document.getElementById('captchaNum1').textContent = n1;
    document.getElementById('captchaNum2').textContent = n2;
  }
}
function checkDeleteWord(v) {
  document.getElementById('resetStep2Btn').disabled = v !== 'DELETE';
}
function checkCaptcha(v) {
  document.getElementById('resetStep3Btn').disabled = Number(v) !== resetCaptchaAnswer;
}
async function executeReset() {
  const btn = document.getElementById('resetStep3Btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Resetting...';
  try {
    await api('/admin/reset-database', { method: 'POST', body: JSON.stringify({ delete_word: 'DELETE' }) });
    bootstrap.Modal.getInstance(document.getElementById('resetModal')).hide();
    showToast('Database reset complete! All data cleared.');
    setTimeout(() => location.reload(), 1500);
  } catch(e) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-trash-alt me-1"></i>Delete Everything';
    showToast(e.message, 'error');
  }
}
</script>
