<%- include('../partials/header') %>
<div class="d-flex">
  <nav class="admin-sidebar d-none d-lg-block">
    <div class="px-3 mb-4"><h5 class="text-white fw-bold"><i class="fas fa-fish me-2"></i>Admin</h5></div>
    <ul class="nav flex-column">
      <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li class="nav-item"><a class="nav-link active" href="/admin/reports"><i class="fas fa-chart-bar"></i> Reports</a></li>
      <li class="nav-item mt-3"><a class="nav-link" href="/"><i class="fas fa-arrow-left"></i> Back</a></li>
    </ul>
  </nav>
  <div class="admin-content flex-grow-1">
    <h3 class="fw-bold mb-4">Reports</h3>
    <ul class="nav nav-tabs mb-4" id="reportTabs">
      <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#salesReport" onclick="loadSalesReport()">Sales</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#productReport" onclick="loadProductReport()">Products</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#stockReport" onclick="loadStockReport()">Stock</a></li>
    </ul>
    <div class="tab-content">
      <div class="tab-pane fade show active" id="salesReport">
        <div class="d-flex gap-2 mb-3"><select class="form-select" id="salesPeriod" style="width:150px" onchange="loadSalesReport()"><option value="daily">Daily</option><option value="weekly">Weekly</option><option value="monthly">Monthly</option><option value="yearly">Yearly</option></select></div>
        <div class="card border-0 shadow-sm"><div class="card-body"><table class="table table-hover mb-0"><thead><tr><th>Period</th><th>Orders</th><th>Subtotal</th><th>Discount</th><th>Shipping</th><th>Revenue</th></tr></thead><tbody id="salesTable"></tbody></table></div></div>
      </div>
      <div class="tab-pane fade" id="productReport">
        <div class="card border-0 shadow-sm"><div class="card-body"><table class="table table-hover mb-0"><thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Sold</th><th>Profit/Unit</th><th>Total Profit</th></tr></thead><tbody id="prodReportTable"></tbody></table></div></div>
      </div>
      <div class="tab-pane fade" id="stockReport">
        <div class="card border-0 shadow-sm"><div class="card-body"><h5>Total Stock Value: <span id="stockValue" class="text-primary"></span></h5><table class="table table-hover mb-0"><thead><tr><th>Product</th><th>Category</th><th>Stock</th><th>Cost Price</th><th>Value</th></tr></thead><tbody id="stockTable"></tbody></table></div></div>
      </div>
    </div>
  </div>
</div>
<script>
async function loadSalesReport(){try{const d=await api(`/reports/sales?period=${document.getElementById('salesPeriod').value}`);document.getElementById('salesTable').innerHTML=d.sales.map(s=>`<tr><td>${s.period}</td><td>${s.orders}</td><td>₹${(s.subtotal||0).toLocaleString()}</td><td>₹${(s.discount||0).toLocaleString()}</td><td>₹${(s.shipping||0).toLocaleString()}</td><td><strong>₹${(s.revenue||0).toLocaleString()}</strong></td></tr>`).join('')||'<tr><td colspan="6" class="text-center text-muted">No data</td></tr>';}catch(e){}}
async function loadProductReport(){try{const d=await api('/reports/products');document.getElementById('prodReportTable').innerHTML=d.products.map(p=>`<tr><td>${p.name}</td><td>${p.category_name||'-'}</td><td>₹${p.price}</td><td>${p.sold_count}</td><td>₹${(p.profit_per_unit||0).toFixed(0)}</td><td>₹${(p.total_profit||0).toLocaleString()}</td></tr>`).join('');}catch(e){}}
async function loadStockReport(){try{const d=await api('/reports/stock');document.getElementById('stockValue').textContent='₹'+d.totalValue.toLocaleString();document.getElementById('stockTable').innerHTML=d.products.map(p=>`<tr><td>${p.name}</td><td>${p.category_name||'-'}</td><td>${p.stock_quantity}</td><td>₹${p.cost_price}</td><td>₹${p.stock_value.toLocaleString()}</td></tr>`).join('');}catch(e){}}
document.addEventListener('DOMContentLoaded',loadSalesReport);
</script>
<%- include('../partials/footer') %>