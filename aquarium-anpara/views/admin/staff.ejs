<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex align-items-center mb-4"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Staff Permissions</h3></div>
    <div id="staffList"></div>
  </div>
</div>

<script>
const SECTIONS = [
  { key: 'dashboard', label: 'Dashboard', icon: 'tachometer-alt' },
  { key: 'products', label: 'Products', icon: 'box' },
  { key: 'categories', label: 'Categories', icon: 'tags' },
  { key: 'brands', label: 'Brands', icon: 'star' },
  { key: 'orders', label: 'Orders', icon: 'shopping-bag' },
  { key: 'customers', label: 'Customers', icon: 'users' },
  { key: 'inventory', label: 'Inventory', icon: 'warehouse' },
  { key: 'coupons', label: 'Coupons', icon: 'ticket-alt' },
  { key: 'reviews', label: 'Reviews', icon: 'star-half-alt' },
  { key: 'reports', label: 'Reports', icon: 'chart-bar' },
  { key: 'banners', label: 'Banners', icon: 'image' },
  { key: 'gallery', label: 'Gallery', icon: 'images' },
  { key: 'messages', label: 'Messages', icon: 'envelope' },
  { key: 'settings', label: 'Settings', icon: 'cog' }
];

async function loadStaff() {
  try {
    const data = await api('/staff');
    const container = document.getElementById('staffList');
    if (!data.staff.length) {
      container.innerHTML = '<div class="text-center py-5"><i class="fas fa-users fa-3x text-muted mb-3"></i><h5>No staff members found</h5><p class="text-muted">Create staff accounts from the <a href="/admin/users">Users</a> page first.</p></div>';
      return;
    }
    container.innerHTML = data.staff.map(s => `
      <div class="glass-card p-4 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h5 class="fw-bold mb-0"><i class="fas fa-user me-2"></i>${s.name}</h5>
            <small class="text-muted">${s.email}</small>
            <span class="badge bg-${s.is_active ? 'success' : 'secondary'} ms-2">${s.is_active ? 'Active' : 'Inactive'}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" onclick="selectAllView(${s.id})">All View</button>
            <button class="btn btn-sm btn-outline-success" onclick="selectAllEdit(${s.id})">All Edit</button>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
              <tr>
                <th style="width:40%">Section</th>
                <th style="width:30%" class="text-center">View</th>
                <th style="width:30%" class="text-center">Edit</th>
              </tr>
            </thead>
            <tbody>
              ${SECTIONS.map(sec => {
                const perms = s.permissions ? JSON.parse(s.permissions) : [];
                const hasView = perms.includes(sec.key) || perms.includes(sec.key + ':write');
                const hasEdit = perms.includes(sec.key + ':write');
                return `
                  <tr>
                    <td><i class="fas fa-${sec.icon} me-2 text-muted"></i>${sec.label}</td>
                    <td class="text-center">
                      <input class="form-check-input perm-view" type="checkbox" data-staff="${s.id}" data-section="${sec.key}" ${hasView ? 'checked' : ''}>
                    </td>
                    <td class="text-center">
                      <input class="form-check-input perm-edit" type="checkbox" data-staff="${s.id}" data-section="${sec.key}" ${hasEdit ? 'checked' : ''}>
                    </td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        </div>
        <div class="mt-3 text-end">
          <button class="btn btn-primary btn-sm" onclick="savePermissions(${s.id})"><i class="fas fa-save me-1"></i>Save Permissions</button>
        </div>
      </div>
    `).join('');
    // Edit implies View: when edit is checked, auto-check view
    document.querySelectorAll('.perm-edit').forEach(cb => {
      cb.addEventListener('change', function() {
        if (this.checked) {
          const staffId = this.dataset.staff;
          const section = this.dataset.section;
          document.querySelector(`.perm-view[data-staff="${staffId}"][data-section="${section}"]`).checked = true;
        }
      });
    });
  } catch(e) { showToast('Failed to load staff', 'error'); }
}

function selectAllView(staffId) {
  const checks = document.querySelectorAll(`.perm-view[data-staff="${staffId}"]`);
  const allChecked = Array.from(checks).every(c => c.checked);
  checks.forEach(c => c.checked = !allChecked);
}

function selectAllEdit(staffId) {
  const checks = document.querySelectorAll(`.perm-edit[data-staff="${staffId}"]`);
  const allChecked = Array.from(checks).every(c => c.checked);
  checks.forEach(c => {
    c.checked = !allChecked;
    if (c.checked) {
      const staffId = c.dataset.staff;
      const section = c.dataset.section;
      document.querySelector(`.perm-view[data-staff="${staffId}"][data-section="${section}"]`).checked = true;
    }
  });
}

function savePermissions(staffId) {
  const permissions = [];
  document.querySelectorAll(`.perm-view[data-staff="${staffId}"]:checked`).forEach(cb => {
    permissions.push(cb.dataset.section);
  });
  document.querySelectorAll(`.perm-edit[data-staff="${staffId}"]:checked`).forEach(cb => {
    const key = cb.dataset.section + ':write';
    if (!permissions.includes(key)) permissions.push(key);
  });
  api(`/staff/${staffId}/permissions`, { method: 'PUT', body: JSON.stringify({ permissions }) })
    .then(() => showToast('Permissions saved!'))
    .catch(e => showToast(e.message, 'error'));
}

document.addEventListener('DOMContentLoaded', loadStaff);
</script>
<%- include('../partials/footer') %>