<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/admin-sidebar') %>
  <div class="admin-content flex-grow-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center"><button class="admin-sidebar-toggle" onclick="toggleAdminSidebar()"><i class="fas fa-bars"></i></button><h3 class="fw-bold mb-0">Gallery</h3></div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#galleryModal"><i class="fas fa-plus me-1"></i>Add Image</button>
    </div>
    <div class="row g-3" id="galleryGrid"></div>
  </div>
</div>
<div class="modal fade" id="galleryModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Add Image</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label">Title</label><input type="text" class="form-control" id="gTitle"></div>
    <div class="mb-3"><label class="form-label">Gallery Image</label><input type="file" class="form-control" id="gFile" accept="image/*" required><div id="gImgPreview" class="mt-2"></div><input type="hidden" id="gImage"></div>
    <div class="mb-3"><label class="form-label">Category</label><select class="form-select" id="gCategory"><option value="aquarium">Aquarium</option><option value="dogs">Dogs</option><option value="cats">Cats</option><option value="birds">Birds</option><option value="store">Store</option></select></div>
  </div>
  <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveGalleryImage()">Save</button></div>
</div></div></div>
<script>
async function loadGallery(){try{const d=await api('/gallery');document.getElementById('galleryGrid').innerHTML=d.images.map(img=>`<div class="col-6 col-md-4 col-lg-3"><div class="card border-0 shadow-sm"><img src="${img.image}" class="card-img-top" style="height:150px;object-fit:cover" onerror="this.style.display='none'"><div class="card-body d-flex justify-content-between align-items-center"><small>${img.title||''}</small><button class="btn btn-sm btn-outline-danger" onclick="deleteGalleryImage(${img.id})"><i class="fas fa-trash"></i></button></div></div></div>`).join('');}catch(e){}}
async function saveGalleryImage(){try{const fileInput=document.getElementById('gFile');if(!fileInput.files.length){showToast('Please select an image','error');return;}const imageUrl=await uploadFile(fileInput.files[0],'gallery');await api('/gallery',{method:'POST',body:JSON.stringify({title:document.getElementById('gTitle').value,image:imageUrl,category:document.getElementById('gCategory').value})});bootstrap.Modal.getInstance(document.getElementById('galleryModal')).hide();showToast('Saved');loadGallery();}catch(e){showToast(e.message,'error');}}
async function deleteGalleryImage(id){if(!confirm('Delete?'))return;try{await api(`/gallery/${id}`,{method:'DELETE'});showToast('Deleted');loadGallery();}catch(e){}}
document.addEventListener('DOMContentLoaded',loadGallery);
</script>
<%- include('../partials/footer') %>