<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= seo?.title || title %> | <%= shopName %></title>
  <meta name="description" content="<%= seo?.description || shopName + ' - Premium pet and aquarium store. Shop aquarium fish, dogs, cats, birds, pet food, aquarium supplies, and accessories with doorstep delivery.' %>">
  <meta name="keywords" content="<%= seo?.keywords || metaKeywords || 'aquarium shop, pet store, aquarium fish, tropical fish, pet supplies, aquarium tanks, fish food, pet food, aquarium plants, aquarium accessories' %>">
<% if (googleVerification) { %>
  <meta name="google-site-verification" content="<%= googleVerification %>">
<% } %>
<% if (seo?.robots) { %>
  <meta name="robots" content="<%= seo.robots %>">
<% } else { %>
  <meta name="robots" content="index, follow">
<% } %>
  <meta name="author" content="<%= shopName %>">
  <link rel="canonical" href="https://<%= shopDomain || 'aquarium-anpara.com' %><%= seo?.canonical || currentPath || '/' %>">
  <meta property="og:title" content="<%= seo?.title || title %> | <%= shopName %>">
  <meta property="og:description" content="<%= seo?.description || 'Premium pet and aquarium store - Quality pet food, accessories, medicines & more at your doorstep.' %>">
  <meta property="og:type" content="<%= seo?.og_type || 'website' %>">
  <meta property="og:url" content="https://<%= shopDomain || 'aquarium-anpara.com' %><%= seo?.canonical || currentPath || '/' %>">
  <meta property="og:site_name" content="<%= shopName %>">
<% if (seo?.og_image) { %>
  <meta property="og:image" content="https://<%= shopDomain || 'aquarium-anpara.com' %><%= seo.og_image %>">
  <meta property="og:image:width" content="800">
  <meta property="og:image:height" content="800">
<% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= seo?.title || title %> | <%= shopName %>">
  <meta name="twitter:description" content="<%= seo?.description || 'Premium pet and aquarium store - Quality products with doorstep delivery.' %>">
<% if (seo?.og_image) { %>
  <meta name="twitter:image" content="https://<%= shopDomain || 'aquarium-anpara.com' %><%= seo.og_image %>">
<% } %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "<%= shopName %>",
    "image": "/images/hero-pet.png",
    "description": "Premium pet and aquarium store offering aquarium fish, pets, pet food, accessories and expert setup services.",
    "address": { "@type": "PostalAddress", "addressLocality": "Anpara", "addressRegion": "UP", "addressCountry": "IN" },
    "telephone": "<%= shopPhone %>",
    "email": "<%= shopEmail %>",
    "url": "https://<%= shopDomain || 'aquarium-anpara.com' %>",
    "sameAs": ["https://facebook.com/","https://instagram.com/","https://youtube.com/"]
  }
  </script>
<% if (seo?.breadcrumb) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": <%= JSON.stringify(seo.breadcrumb) %>
  }
  </script>
<% } %>
<% if (seo?.product) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "<%= seo.product.name %>",
    "description": "<%= seo.product.description %>",
    "sku": "<%= seo.product.sku || '' %>",
    "brand": { "@type": "Brand", "name": "<%= seo.product.brand || '' %>" },
    "image": <%= JSON.stringify(seo.product.images) %>,
    "offers": {
      "@type": "Offer",
      "url": "https://<%= shopDomain || 'aquarium-anpara.com' %>/product/<%= seo.product.slug %>",
      "priceCurrency": "INR",
      "price": <%= seo.product.price %>,
      "availability": "<%= seo.product.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>",
      "priceValidUntil": "<%= new Date(Date.now() + 365*24*60*60*1000).toISOString().split('T')[0] %>"
    }
  }
  </script>
<% } %>
<% if (seo?.item_list) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": <%= JSON.stringify(seo.item_list) %>
  }
  </script>
<% } %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="/js/app.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','<%= gaId %>');</script>
<% } %>
<% if (fbPixel) { %>
  <script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= fbPixel %>');fbq('track','PageView');</script>
<% } %>
</head>
<body data-whatsapp="<%= whatsappNumber %>">
  <div class="top-bar">
    <div class="container d-flex justify-content-between align-items-center">
      <div>
        <a href="tel:<%= shopPhone %>" class="me-3"><i class="fas fa-phone me-1"></i> <%= shopPhone %></a>
        <a href="mailto:<%= shopEmail %>"><i class="fas fa-envelope me-1"></i> <%= shopEmail %></a>
      </div>
      <div>
        <a href="/track-order" class="me-3"><i class="fas fa-truck me-1"></i> Track Order</a>
        <a href="/contact"><i class="fas fa-map-marker-alt me-1"></i> <%= shopAddress.substring(0,30) %>...</a>
      </div>
    </div>
  </div>

  <nav class="navbar navbar-expand-lg navbar-light bg-white" id="mainNavbar">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="fas fa-fish"></i> <%= shopName %>
      </a>
      <div class="d-flex align-items-center gap-1 d-lg-none">
        <a href="/cart" class="nav-icon position-relative" title="Cart">
          <i class="fas fa-shopping-cart"></i>
          <span class="nav-badge cart-count">0</span>
        </a>
        <div class="dropdown auth-only" style="display:none">
          <a class="nav-link dropdown-toggle px-1" href="#" data-bs-toggle="dropdown">
            <i class="fas fa-user-circle fs-5"></i>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2"></i>My Profile</a></li>
            <li class="customer-only"><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2"></i>My Orders</a></li>
            <li class="customer-only"><a class="dropdown-item" href="/wishlist"><i class="fas fa-heart me-2"></i>Wishlist</a></li>
            <li id="admin-link" style="display:none"><a class="dropdown-item" href="/admin"><i class="fas fa-cog me-2"></i>Admin Panel</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#" onclick="logout()"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
          </ul>
        </div>
        <div class="guest-only">
          <a href="/login" class="btn btn-outline-primary btn-sm px-2">Login</a>
        </div>
        <span id="headerPincodeMobile" class="text-muted small ms-1 d-none d-sm-inline"></span>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
          <span class="navbar-toggler-icon"></span>
        </button>
      </div>

      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/shop' ? 'active' : '' %>" href="/shop">Shop</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/about' ? 'active' : '' %>" href="/about">About</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/gallery' ? 'active' : '' %>" href="/gallery">Gallery</a></li>
          <li class="nav-item"><a class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>" href="/contact">Contact</a></li>
        </ul>
        <div class="d-flex align-items-center gap-2 d-none d-lg-flex">
          <a href="/shop" class="nav-icon" title="Search"><i class="fas fa-search"></i></a>
          <a href="/wishlist" class="nav-icon" title="Wishlist"><i class="far fa-heart"></i></a>
          <a href="/cart" class="nav-icon position-relative" title="Cart">
            <i class="fas fa-shopping-cart"></i>
            <span class="nav-badge cart-count">0</span>
          </a>
          <span id="headerPincode" class="text-muted small ms-2"></span>
          <div class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
            <i class="fas fa-moon"></i>
          </div>
          <div class="dropdown auth-only" style="display:none">
            <a class="nav-link dropdown-toggle px-2" href="#" data-bs-toggle="dropdown">
              <i class="fas fa-user-circle me-1"></i> <span class="user-name">Account</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2"></i>My Profile</a></li>
              <li class="customer-only"><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2"></i>My Orders</a></li>
              <li class="customer-only"><a class="dropdown-item" href="/wishlist"><i class="fas fa-heart me-2"></i>Wishlist</a></li>
              <li id="admin-link" style="display:none"><a class="dropdown-item" href="/admin"><i class="fas fa-cog me-2"></i>Admin Panel</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="#" onclick="logout()"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
            </ul>
          </div>
          <div class="guest-only">
            <a href="/login" class="btn btn-primary btn-sm px-3">Login</a>
          </div>
        </div>
      </div>
    </div>
  </nav>
