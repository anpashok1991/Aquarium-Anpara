<%- include('partials/header') %>
<div class="container py-4">
  <div class="section-title-wrapper text-center mb-5">
    <h2 class="section-title">Gallery</h2>
    <p class="section-subtitle">Explore our beautiful aquarium and pet collections</p>
  </div>
  <div class="d-flex gap-2 mb-4 flex-wrap justify-content-center">
    <button class="btn btn-outline-primary active filter-btn" onclick="filterGallery('', this)">All</button>
    <button class="btn btn-outline-primary filter-btn" onclick="filterGallery('aquarium', this)">Aquarium</button>
    <button class="btn btn-outline-primary filter-btn" onclick="filterGallery('dogs', this)">Dogs</button>
    <button class="btn btn-outline-primary filter-btn" onclick="filterGallery('cats', this)">Cats</button>
    <button class="btn btn-outline-primary filter-btn" onclick="filterGallery('birds', this)">Birds</button>
    <button class="btn btn-outline-primary filter-btn" onclick="filterGallery('store', this)">Store</button>
  </div>
  <div class="row g-3" id="galleryGrid"></div>
</div>
<script>
async function filterGallery(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  try {
    const url = cat ? `/gallery?category=${cat}` : '/gallery';
    const data = await api(url);
    const grid = document.getElementById('galleryGrid');
    grid.innerHTML = data.images.map(img => `
      <div class="col-6 col-md-4 col-lg-3 fade-in">
        <a href="${img.image}" target="_blank" class="text-decoration-none">
          <div class="position-relative rounded overflow-hidden shadow-sm" style="height:220px;border-radius:var(--radius-lg);transition:var(--transition-slow)" onmouseover="this.style.boxShadow='var(--shadow-lg)';this.querySelector('img').style.transform='scale(1.08)'" onmouseout="this.style.boxShadow='var(--shadow)';this.querySelector('img').style.transform='scale(1)'">
            <img src="${img.image}" class="w-100 h-100" style="object-fit:cover;transition:var(--transition-slow)" alt="${img.title||''}" onerror="this.style.display='none'">
            ${img.title ? `<div class="position-absolute bottom-0 start-0 end-0" style="background:linear-gradient(transparent,rgba(0,0,0,0.7));padding:2rem 0.8rem 0.8rem"><small style="color:#fff;font-weight:600">${img.title}</small></div>` : ''}
          </div>
        </a>
      </div>`).join('');
  } catch(e) { document.getElementById('galleryGrid').innerHTML = '<p class="text-muted">No images found</p>'; }
}
document.addEventListener('DOMContentLoaded', () => filterGallery('', null));
</script>
<%- include('partials/footer') %>
