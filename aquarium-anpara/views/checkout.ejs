<%- include('partials/header') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-lock me-2"></i>Checkout</h2>
  <div class="row g-4">
    <div class="col-lg-8">
      <div id="savedAddresses" class="mb-3" style="display:none">
        <div class="glass-card p-3">
          <h5 class="fw-bold mb-3"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Saved Addresses</h5>
          <div id="addressOptions" class="d-flex flex-column gap-2"></div>
          <button class="btn btn-link btn-sm mt-2 p-0" onclick="showManualForm()">+ Enter a different address</button>
        </div>
      </div>

      <form id="checkoutForm" class="glass-card p-4">
        <div id="shippingFields">
          <h5 class="fw-bold mb-3">Shipping Details</h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Full Name *</label>
              <input type="text" class="form-control" id="name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Mobile Number *</label>
              <input type="tel" class="form-control" id="phone" required maxlength="10" pattern="[0-9]{10}" inputmode="numeric" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            </div>
            <div class="col-md-6">
              <label class="form-label">WhatsApp Number</label>
              <input type="tel" class="form-control" id="whatsapp" maxlength="10" pattern="[0-9]{10}" inputmode="numeric" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            </div>
            <div class="col-md-6">
              <label class="form-label">Email (Optional)</label>
              <input type="email" class="form-control" id="email">
            </div>
            <div class="col-12">
              <label class="form-label">Address *</label>
              <textarea class="form-control" id="address" rows="2" required></textarea>
            </div>
            <div class="col-md-4">
              <label class="form-label">City *</label>
              <input type="text" class="form-control" id="city" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">State *</label>
              <input type="text" class="form-control" id="state" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Pincode *</label>
              <input type="text" class="form-control" id="pincode" required>
            </div>
          </div>
        </div>

        <h5 class="fw-bold mt-4 mb-3">Payment Method</h5>
        <div class="d-flex flex-column gap-2" id="paymentMethods">
          <div class="form-check border rounded p-3 pay-option" data-method="cod">
            <input class="form-check-input" type="radio" name="payment" value="cod">
            <label class="form-check-label"><i class="fas fa-money-bill me-2"></i>Cash on Delivery</label>
          </div>
          <div class="form-check border rounded p-3 pay-option" data-method="upi">
            <input class="form-check-input" type="radio" name="payment" value="upi">
            <label class="form-check-label"><i class="fas fa-mobile-alt me-2"></i>UPI Payment</label>
          </div>
          <div class="form-check border rounded p-3 pay-option" data-method="bank_transfer">
            <input class="form-check-input" type="radio" name="payment" value="bank_transfer">
            <label class="form-check-label"><i class="fas fa-university me-2"></i>Bank Transfer</label>
          </div>
          <div class="form-check border rounded p-3 pay-option" data-method="scan_pay">
            <input class="form-check-input" type="radio" name="payment" value="scan_pay">
            <label class="form-check-label"><i class="fas fa-qrcode me-2"></i>Scan & Pay</label>
          </div>
        </div>

        <div class="mt-3">
          <label class="form-label">Order Notes (Optional)</label>
          <textarea class="form-control" id="notes" rows="2" placeholder="Any special instructions..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 mt-4" id="placeOrderBtn">
          <i class="fas fa-check-circle me-2"></i>Place Order
        </button>
      </form>
    </div>

    <div class="col-lg-4">
      <div class="glass-card p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-receipt text-primary me-2"></i>Order Summary</h5>
        <div id="orderSummary"></div>
        <hr>
        <div class="d-flex justify-content-between mb-1"><span>Subtotal</span><span id="sub">₹0</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Delivery</span><span id="del" class="text-success">Free</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Platform Fee</span><span id="pfAmt">₹0</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Discount</span><span id="disc" class="text-danger">-₹0</span></div>
        <div class="d-flex justify-content-between mb-1" id="gstRow"><span>GST</span><span id="gstAmt">₹0</span></div>
        <hr>
        <div class="d-flex justify-content-between fw-bold fs-5"><span>Total</span><span id="tot">₹0</span></div>
      </div>
    </div>
  </div>
</div>

<!-- Scan & Pay Modal -->
<div class="modal fade" id="scanPayModal" data-bs-backdrop="static" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="fas fa-qrcode me-2 text-primary"></i>Scan & Pay</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body text-center">
        <h3 class="fw-bold text-primary mb-1">₹<span id="scanPayAmount">0</span></h3>
        <p class="text-muted small mb-3">Scan any QR below to pay the exact amount</p>
        <div id="dynamicQrWrap" class="mb-3" style="display:none">
          <div class="text-center">
            <img id="dynamicQrImg" src="" alt="Dynamic UPI QR" style="width:180px;height:180px;object-fit:contain;border:2px solid var(--gray-light);border-radius:12px;padding:8px">
            <div class="small mt-1 text-muted">Auto-filled amount QR</div>
          </div>
        </div>
        <div id="scannerList" class="d-flex flex-wrap justify-content-center gap-3 mb-3"></div>
        <div class="alert alert-info small py-2 mb-3"><i class="fas fa-info-circle me-1"></i>Payment confirmation will be completed after Admin approves it.</div>
        <hr>
        <div class="mb-3">
          <label class="form-label fw-bold small">Upload Payment Receipt</label>
          <input type="file" class="form-control form-control-sm" id="paymentReceipt" accept="image/*">
          <div id="receiptPreview" class="mt-2" style="display:none"><img src="" style="max-height:120px;border-radius:8px;border:1px solid var(--gray-light)"></div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold small">Transaction ID / UTR</label>
          <input type="text" class="form-control form-control-sm" id="transactionId" placeholder="Enter transaction reference number">
        </div>
        <div class="d-flex gap-2 justify-content-center">
          <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-primary" id="confirmScanPayBtn" onclick="confirmScanPay()"><i class="fas fa-check me-1"></i>Payment Done</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
let cartItems = [];
let subtotal = 0;
let appliedCoupon = null;
let savedAddresses = [];
let scanPayData = null;

function fillAddress(a) {
  document.getElementById('name').value = a.name || '';
  document.getElementById('phone').value = a.phone || '';
  document.getElementById('address').value = a.address || '';
  document.getElementById('city').value = a.city || '';
  document.getElementById('state').value = a.state || '';
  document.getElementById('pincode').value = a.pincode || '';
}

function selectAddress(a) {
  fillAddress(a);
  document.querySelectorAll('#addressOptions .list-group-item').forEach(el => el.classList.remove('active', 'list-group-item-primary'));
  const el = document.getElementById('addrOption_' + a.id);
  if (el) el.classList.add('active', 'list-group-item-primary');
  // also set whatsapp if available
  if (a.phone) document.getElementById('whatsapp').value = document.getElementById('whatsapp').value || a.phone;
}

function showManualForm() {
  document.querySelectorAll('#addressOptions .list-group-item').forEach(el => el.classList.remove('active', 'list-group-item-primary'));
  document.getElementById('shippingFields').style.display = '';
}

async function loadCheckout() {
  try {
    const [cartData, addrData, settingsData] = await Promise.all([api('/cart'), api('/addresses'), api('/settings')]);
    if (!cartData.items.length) { window.location.href = '/cart'; return; }
    cartItems = cartData.items;
    subtotal = cartData.subtotal;
    savedAddresses = addrData.addresses || [];

    // Buy Now: filter to only the clicked product
    const params = new URLSearchParams(window.location.search);
    const buyNowProductId = sessionStorage.getItem('buyNowProductId');
    if (params.get('buy_now') === '1' && buyNowProductId) {
      cartItems = cartItems.filter(i => String(i.product_id) === buyNowProductId);
      subtotal = cartItems.reduce((s, i) => s + (i.unit_price || i.discount_price > 0 ? i.discount_price : i.price) * i.quantity, 0);
    }

    const payMethods = settingsData.settings?.payment_methods;
    if (payMethods) {
      let enabled = [];
      try { enabled = JSON.parse(payMethods); } catch { enabled = ['cod']; }
      document.querySelectorAll('.pay-option').forEach(el => {
        const isEnabled = enabled.includes(el.dataset.method);
        el.style.display = isEnabled ? '' : 'none';
        el.classList.toggle('disabled', !isEnabled);
        el.querySelector('input').disabled = !isEnabled;
      });
      const firstVisible = document.querySelector('.pay-option:not([style*="display: none"]) input');
      if (firstVisible) firstVisible.checked = true;
    // Load scanner QR images + UPI ID
    const upiId = settingsData.settings?.upi_id || '';
    window._upiId = upiId;
    window._platformFee = settingsData.settings?.platform_fee || '0';
    const s1 = settingsData.settings?.scanner_1, s2 = settingsData.settings?.scanner_2;
      let q1, q2;
      try { q1 = JSON.parse(s1 || '{}'); } catch { q1 = {}; }
      try { q2 = JSON.parse(s2 || '{}'); } catch { q2 = {}; }
      const scanners = [q1, q2].filter(s => s && s.qr);
      const list = document.getElementById('scannerList');
      if (scanners.length) {
        list.innerHTML = scanners.map(s => `
          <div class="text-center" style="width:180px">
            <img src="${s.qr}" alt="${s.name || 'Scanner'}" style="width:160px;height:160px;object-fit:contain;border:2px solid var(--gray-light);border-radius:12px;padding:8px">
            <div class="small mt-2 fw-bold">${s.name || ''}</div>
          </div>`).join('');
      } else {
        list.innerHTML = '<p class="text-muted small">No payment scanners configured yet.</p>';
      }
    }
    if (!document.querySelector('.pay-option:not([style*="display: none"])')) {
      document.querySelector('.pay-option[data-method="cod"]').style.display = '';
    }

    const saved = localStorage.getItem('coupon');
    if (saved) {
      try { appliedCoupon = JSON.parse(saved); } catch { localStorage.removeItem('coupon'); }
    }

    if (savedAddresses.length) {
      document.getElementById('savedAddresses').style.display = '';
      document.getElementById('shippingFields').style.display = 'none';
      const container = document.getElementById('addressOptions');
      container.innerHTML = savedAddresses.map(a => `
        <div class="list-group-item list-group-item-action rounded p-2 cursor-pointer ${a.is_primary ? 'active list-group-item-primary' : ''}"
             id="addrOption_${a.id}" onclick="selectAddress(${JSON.stringify(a).replace(/"/g, '&quot;')})" style="cursor:pointer">
          <div class="d-flex justify-content-between">
            <span><strong>${a.label}</strong>${a.is_primary ? ' <span class="badge bg-success ms-1">Primary</span>' : ''}</span>
            <small>${a.pincode}</small>
          </div>
          <small>${a.name}, ${a.address}, ${a.city}, ${a.state} - ${a.pincode}</small>
        </div>`).join('');

      const primary = savedAddresses.find(a => a.is_primary) || savedAddresses[0];
      fillAddress(primary);
      const el = document.getElementById('addrOption_' + primary.id);
      if (el) el.classList.add('active', 'list-group-item-primary');
    } else {
      const user = getUser();
      if (user) {
        document.getElementById('name').value = user.name || '';
        document.getElementById('phone').value = user.phone || '';
        document.getElementById('email').value = user.email || '';
      }
    }
    renderSummary();
  } catch (e) { showToast(e.message || 'Failed to load checkout', 'error'); }
}

function renderSummary() {
  const summary = document.getElementById('orderSummary');
  summary.innerHTML = cartItems.map(i => {
    const pct = i.gst_percent || 0;
    const lineTotal = i.unit_price * i.quantity;
    const gstAmt = pct > 0 ? lineTotal * pct / (100 + pct) : 0;
    const baseTotal = lineTotal - gstAmt;
    return `<div class="d-flex justify-content-between mb-1"><small>${i.name} x${i.quantity}</small><small>₹${baseTotal.toLocaleString()}${pct > 0 ? ' + ₹' + gstAmt.toLocaleString() + ' GST' : ''} = ₹${lineTotal.toLocaleString()}</small></div>`;
  }).join('');
  const delivery = subtotal >= 500 ? 0 : 50;
  const discount = appliedCoupon ? appliedCoupon.discount : 0;
  let tax = 0;
  cartItems.forEach(i => {
    const pct = i.gst_percent || 0;
    const lineTotal = i.unit_price * i.quantity;
    tax += pct > 0 ? lineTotal * pct / (100 + pct) : 0;
  });
  const platformFee = parseFloat(window._platformFee || '0');
  const total = subtotal - discount + delivery + platformFee;
  document.getElementById('sub').textContent = '₹' + subtotal.toLocaleString();
  document.getElementById('del').textContent = delivery === 0 ? 'Free' : '₹' + delivery;
  document.getElementById('pfAmt').textContent = platformFee > 0 ? '₹' + platformFee.toLocaleString() : '₹0';
  document.getElementById('disc').textContent = discount > 0 ? '-₹' + discount.toLocaleString() : '-₹0';
  document.getElementById('gstAmt').textContent = tax > 0 ? '₹' + tax.toLocaleString() : '₹0';
  document.getElementById('gstRow').style.display = tax > 0 ? '' : 'none';
  document.getElementById('tot').textContent = '₹' + total.toLocaleString();
  document.getElementById('scanPayAmount').textContent = total.toLocaleString();
  // Update dynamic UPI QR with current total
  const upiId = window._upiId;
  if (upiId) {
    const shopName = 'Aquarium Anpara';
    const upiLink = `upi://pay?pa=${encodeURIComponent(upiId)}&pn=${encodeURIComponent(shopName)}&am=${total.toFixed(2)}&cu=INR`;
    const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(upiLink)}`;
    document.getElementById('dynamicQrImg').src = qrUrl;
    document.getElementById('dynamicQrWrap').style.display = '';
  }
}

document.getElementById('checkoutForm').addEventListener('submit', async (e) => {
  e.preventDefault();

  const paySelected = document.querySelector('input[name="payment"]:checked');
  if (!paySelected) { showToast('Please select a payment method', 'error'); return; }
  if (paySelected.value === 'scan_pay' && !scanPayData) {
    const modal = new bootstrap.Modal(document.getElementById('scanPayModal'));
    modal.show();
    return;
  }

  const btn = document.getElementById('placeOrderBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Placing Order...';

  const orderData = {
    customer_name: document.getElementById('name').value,
    customer_phone: document.getElementById('phone').value,
    customer_whatsapp: document.getElementById('whatsapp').value || document.getElementById('phone').value,
    customer_email: document.getElementById('email').value,
    shipping_address: document.getElementById('address').value,
    shipping_city: document.getElementById('city').value,
    shipping_state: document.getElementById('state').value,
    shipping_pincode: document.getElementById('pincode').value,
    payment_method: paySelected.value,
    payment_screenshot: scanPayData ? scanPayData.screenshot : null,
    transaction_id: scanPayData ? scanPayData.txid : null,
    notes: document.getElementById('notes').value,
    coupon_code: appliedCoupon ? appliedCoupon.code : null
  };

  const params = new URLSearchParams(window.location.search);
  if (params.get('buy_now') === '1') {
    const bpid = sessionStorage.getItem('buyNowProductId');
    orderData.buy_now = '1';
    orderData.buy_now_product_id = bpid || '';
  }

  try {
    const order = await placeOrder(orderData);
    if (order) {
      localStorage.removeItem('coupon');
      sessionStorage.removeItem('buyNowProductId');
      window.location.href = '/order-confirmation/' + order.order_number + '?pay=' + order.payment_method;
    }
  } catch (e) {
    showToast(e.message, 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-check-circle me-2"></i>Place Order';
});

document.addEventListener('DOMContentLoaded', loadCheckout);

document.querySelectorAll('input[name="payment"]').forEach(r => r.addEventListener('change', function() {
  if (this.value === 'scan_pay') {
    const modal = new bootstrap.Modal(document.getElementById('scanPayModal'));
    modal.show();
  }
}));

document.getElementById('paymentReceipt').addEventListener('change', function() {
  const preview = document.getElementById('receiptPreview');
  if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.querySelector('img').src = e.target.result; preview.style.display = ''; };
    reader.readAsDataURL(this.files[0]);
  }
});

async function confirmScanPay() {
  const fileInput = document.getElementById('paymentReceipt');
  const txid = document.getElementById('transactionId').value.trim();
  try {
    let screenshotUrl = scanPayData?.screenshot || '';
    if (fileInput.files.length > 0) {
      screenshotUrl = await fileToBase64(fileInput.files[0]);
    }
    if (!txid && !screenshotUrl) {
      showToast('Please upload a receipt or enter a transaction ID', 'error');
      return;
    }
    scanPayData = { screenshot: screenshotUrl, txid: txid || null };
    bootstrap.Modal.getInstance(document.getElementById('scanPayModal')).hide();
    showToast('Payment info recorded. Click Place Order to continue.');
  } catch(e) {
    showToast('Failed to process payment info: ' + e.message, 'error');
  }
}
function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}
</script>
<%- include('partials/footer') %>