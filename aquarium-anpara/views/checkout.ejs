<%- include('partials/header') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-lock me-2"></i>Checkout</h2>
  <div class="row g-4">
    <div class="col-lg-8">
      <div id="savedAddresses" class="mb-3" style="display:none">
        <div class="glass-card p-3">
          <h5 class="fw-bold mb-3"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Saved Addresses</h5>
          <div id="addressOptions" class="d-flex flex-column gap-2"></div>
          <button class="btn btn-link btn-sm mt-2 p-0" onclick="showManualForm()">+ Enter a different address</button>
        </div>
      </div>

      <form id="checkoutForm" class="glass-card p-4">
        <div id="shippingFields">
          <h5 class="fw-bold mb-3">Shipping Details</h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Full Name *</label>
              <input type="text" class="form-control" id="name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Mobile Number *</label>
              <input type="tel" class="form-control" id="phone" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">WhatsApp Number</label>
              <input type="tel" class="form-control" id="whatsapp">
            </div>
            <div class="col-md-6">
              <label class="form-label">Email (Optional)</label>
              <input type="email" class="form-control" id="email">
            </div>
            <div class="col-12">
              <label class="form-label">Address *</label>
              <textarea class="form-control" id="address" rows="2" required></textarea>
            </div>
            <div class="col-md-4">
              <label class="form-label">City *</label>
              <input type="text" class="form-control" id="city" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">State *</label>
              <input type="text" class="form-control" id="state" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Pincode *</label>
              <input type="text" class="form-control" id="pincode" required>
            </div>
          </div>
        </div>

        <h5 class="fw-bold mt-4 mb-3">Payment Method</h5>
        <div class="d-flex flex-column gap-2">
          <div class="form-check border rounded p-3">
            <input class="form-check-input" type="radio" name="payment" id="cod" value="cod" checked>
            <label class="form-check-label" for="cod"><i class="fas fa-money-bill me-2"></i>Cash on Delivery</label>
          </div>
          <div class="form-check border rounded p-3">
            <input class="form-check-input" type="radio" name="payment" id="upi" value="upi">
            <label class="form-check-label" for="upi"><i class="fas fa-mobile-alt me-2"></i>UPI Payment</label>
          </div>
          <div class="form-check border rounded p-3">
            <input class="form-check-input" type="radio" name="payment" id="bank" value="bank_transfer">
            <label class="form-check-label" for="bank"><i class="fas fa-university me-2"></i>Bank Transfer</label>
          </div>
        </div>

        <div class="mt-3">
          <label class="form-label">Order Notes (Optional)</label>
          <textarea class="form-control" id="notes" rows="2" placeholder="Any special instructions..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 mt-4" id="placeOrderBtn">
          <i class="fas fa-check-circle me-2"></i>Place Order
        </button>
      </form>
    </div>

    <div class="col-lg-4">
      <div class="glass-card p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-receipt text-primary me-2"></i>Order Summary</h5>
        <div id="orderSummary"></div>
        <hr>
        <div class="d-flex justify-content-between mb-1"><span>Subtotal</span><span id="sub">₹0</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Delivery</span><span id="del" class="text-success">Free</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Discount</span><span id="disc" class="text-danger">-₹0</span></div>
        <hr>
        <div class="d-flex justify-content-between fw-bold fs-5"><span>Total</span><span id="tot">₹0</span></div>
      </div>
    </div>
  </div>
</div>

<script>
let cartItems = [];
let subtotal = 0;
let appliedCoupon = null;
let savedAddresses = [];

function fillAddress(a) {
  document.getElementById('name').value = a.name || '';
  document.getElementById('phone').value = a.phone || '';
  document.getElementById('address').value = a.address || '';
  document.getElementById('city').value = a.city || '';
  document.getElementById('state').value = a.state || '';
  document.getElementById('pincode').value = a.pincode || '';
}

function selectAddress(a) {
  fillAddress(a);
  document.querySelectorAll('#addressOptions .list-group-item').forEach(el => el.classList.remove('active', 'list-group-item-primary'));
  const el = document.getElementById('addrOption_' + a.id);
  if (el) el.classList.add('active', 'list-group-item-primary');
  // also set whatsapp if available
  if (a.phone) document.getElementById('whatsapp').value = document.getElementById('whatsapp').value || a.phone;
}

function showManualForm() {
  document.querySelectorAll('#addressOptions .list-group-item').forEach(el => el.classList.remove('active', 'list-group-item-primary'));
  document.getElementById('shippingFields').style.display = '';
}

async function loadCheckout() {
  try {
    const [cartData, addrData] = await Promise.all([api('/cart'), api('/addresses')]);
    if (!cartData.items.length) { window.location.href = '/cart'; return; }
    cartItems = cartData.items;
    subtotal = cartData.subtotal;
    savedAddresses = addrData.addresses || [];

    const saved = localStorage.getItem('coupon');
    if (saved) {
      try { appliedCoupon = JSON.parse(saved); } catch { localStorage.removeItem('coupon'); }
    }

    if (savedAddresses.length) {
      document.getElementById('savedAddresses').style.display = '';
      document.getElementById('shippingFields').style.display = 'none';
      const container = document.getElementById('addressOptions');
      container.innerHTML = savedAddresses.map(a => `
        <div class="list-group-item list-group-item-action rounded p-2 cursor-pointer ${a.is_primary ? 'active list-group-item-primary' : ''}"
             id="addrOption_${a.id}" onclick="selectAddress(${JSON.stringify(a).replace(/"/g, '&quot;')})" style="cursor:pointer">
          <div class="d-flex justify-content-between">
            <span><strong>${a.label}</strong>${a.is_primary ? ' <span class="badge bg-success ms-1">Primary</span>' : ''}</span>
            <small>${a.pincode}</small>
          </div>
          <small>${a.name}, ${a.address}, ${a.city}, ${a.state} - ${a.pincode}</small>
        </div>`).join('');

      const primary = savedAddresses.find(a => a.is_primary) || savedAddresses[0];
      fillAddress(primary);
      const el = document.getElementById('addrOption_' + primary.id);
      if (el) el.classList.add('active', 'list-group-item-primary');
    } else {
      const user = getUser();
      if (user) {
        document.getElementById('name').value = user.name || '';
        document.getElementById('phone').value = user.phone || '';
        document.getElementById('email').value = user.email || '';
      }
    }
    renderSummary();
  } catch (e) { showToast(e.message || 'Failed to load checkout', 'error'); }
}

function renderSummary() {
  const summary = document.getElementById('orderSummary');
  summary.innerHTML = cartItems.map(i => `<div class="d-flex justify-content-between mb-1"><small>${i.name} x${i.quantity}</small><small>₹${(i.unit_price * i.quantity).toLocaleString()}</small></div>`).join('');
  const delivery = subtotal >= 500 ? 0 : 50;
  const discount = appliedCoupon ? appliedCoupon.discount : 0;
  const total = subtotal - discount + delivery;
  document.getElementById('sub').textContent = '₹' + subtotal.toLocaleString();
  document.getElementById('del').textContent = delivery === 0 ? 'Free' : '₹' + delivery;
  document.getElementById('disc').textContent = discount > 0 ? '-₹' + discount.toLocaleString() : '-₹0';
  document.getElementById('tot').textContent = '₹' + total.toLocaleString();
}

document.getElementById('checkoutForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('placeOrderBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Placing Order...';

  const orderData = {
    customer_name: document.getElementById('name').value,
    customer_phone: document.getElementById('phone').value,
    customer_whatsapp: document.getElementById('whatsapp').value || document.getElementById('phone').value,
    customer_email: document.getElementById('email').value,
    shipping_address: document.getElementById('address').value,
    shipping_city: document.getElementById('city').value,
    shipping_state: document.getElementById('state').value,
    shipping_pincode: document.getElementById('pincode').value,
    payment_method: document.querySelector('input[name="payment"]:checked').value,
    notes: document.getElementById('notes').value,
    coupon_code: appliedCoupon ? appliedCoupon.code : null,
    discount: appliedCoupon ? appliedCoupon.discount : 0
  };

  try {
    const order = await placeOrder(orderData);
    if (order) {
      localStorage.removeItem('coupon');
      window.location.href = '/order-confirmation/' + order.order_number;
    }
  } catch (e) {
    showToast(e.message, 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-check-circle me-2"></i>Place Order';
});

document.addEventListener('DOMContentLoaded', loadCheckout);
</script>
<%- include('partials/footer') %>