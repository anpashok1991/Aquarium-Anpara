<%- include('partials/header') %>

<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item active">Shop</li>
    </ol>
  </nav>

  <div class="row">
    <div class="col-lg-3 mb-4">
      <!-- Mobile: search bar + filter button -->
      <div class="d-lg-none mb-3">
        <div class="input-group mb-2">
          <input type="text" class="form-control" id="mobileSearchInput" placeholder="Search products...">
          <button class="btn btn-primary" onclick="mobileSearch()"><i class="fas fa-search"></i></button>
        </div>
        <button class="btn btn-outline-primary w-100" data-bs-toggle="offcanvas" data-bs-target="#filterOffcanvas">
          <i class="fas fa-filter me-1"></i>Filters
        </button>
      </div>

      <!-- Desktop: full filter sidebar -->
      <div class="card border-0 shadow-sm d-none d-lg-block">
        <div class="card-body">
          <h5 class="fw-bold mb-3">Filters</h5>
          
          <div class="mb-3">
            <label class="form-label fw-semibold">Search</label>
            <div class="input-group">
              <input type="text" class="form-control" id="searchInput" placeholder="Search products...">
              <button class="btn btn-primary" onclick="loadShopProducts()"><i class="fas fa-search"></i></button>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Category</label>
            <select class="form-select" id="categoryFilter">
              <option value="">All Categories</option>
              <% function renderCatOptions(parentId, depth) {
                   let html = '';
                   const filtered = categories.filter(c => (c.parent_id || null) === (parentId || null));
                   filtered.sort((a,b) => (a.sort_order||0) - (b.sort_order||0) || a.name.localeCompare(b.name));
                   filtered.forEach(c => {
                     const indent = '&nbsp;'.repeat(depth * 3);
                     html += `<option value="${c.slug}">${indent}${c.name}</option>`;
                     html += renderCatOptions(c.id, depth + 1);
                   });
                   return html;
                 } %><%- renderCatOptions(null, 0) %>
            </select>
          </div>

          <div class="mb-3" id="brandFilterWrap">
            <label class="form-label fw-semibold">Brand</label>
            <select class="form-select" id="brandFilter">
              <option value="">All Brands</option>
              <% brands.forEach(b => { %>
              <option value="<%= b.slug %>"><%= b.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3" id="breedFilterWrap" style="display:none">
            <label class="form-label fw-semibold">Breed</label>
            <select class="form-select" id="breedFilter">
              <option value="">All Breeds</option>
              <% breeds.filter(b => b.is_active).forEach(b => { %>
              <option value="<%= b.slug %>" data-cat="<%= b.category_id %>"><%= b.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Price Range</label>
            <div class="d-flex gap-2">
              <input type="number" class="form-control" id="minPrice" placeholder="Min">
              <input type="number" class="form-control" id="maxPrice" placeholder="Max">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Sort By</label>
            <select class="form-select" id="sortFilter">
              <option value="newest">Newest</option>
              <option value="price_asc">Price: Low to High</option>
              <option value="price_desc">Price: High to Low</option>
              <option value="popular">Most Popular</option>
              <option value="rating">Top Rated</option>
            </select>
          </div>

          <div class="mb-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="inStock">
              <label class="form-check-label">In Stock Only</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="onSale">
              <label class="form-check-label">On Sale</label>
            </div>
          </div>

          <button class="btn btn-primary w-100 mb-2" onclick="loadShopProducts()"><i class="fas fa-filter me-1"></i>Apply Filters</button>
          <button class="btn btn-outline-secondary btn-sm w-100" onclick="resetFilters()">Clear Filters</button>
        </div>
      </div>
    </div>

    <!-- Mobile Filter Offcanvas -->
    <div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="filterOffcanvas">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title fw-bold">Filters</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
      </div>
      <div class="offcanvas-body">
        <div class="mb-3">
          <label class="form-label fw-semibold">Category</label>
          <select class="form-select" id="mobileCategoryFilter">
            <option value="">All Categories</option>
            <%- renderCatOptions(null, 0) %>
          </select>
        </div>
        <div class="mb-3" id="mobileBrandFilterWrap">
          <label class="form-label fw-semibold">Brand</label>
          <select class="form-select" id="mobileBrandFilter">
            <option value="">All Brands</option>
            <% brands.forEach(b => { %>
            <option value="<%= b.slug %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3" id="mobileBreedFilterWrap" style="display:none">
          <label class="form-label fw-semibold">Breed</label>
          <select class="form-select" id="mobileBreedFilter">
            <option value="">All Breeds</option>
            <% breeds.filter(b => b.is_active).forEach(b => { %>
            <option value="<%= b.slug %>" data-cat="<%= b.category_id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Price Range</label>
          <div class="d-flex gap-2">
            <input type="number" class="form-control" id="mobileMinPrice" placeholder="Min">
            <input type="number" class="form-control" id="mobileMaxPrice" placeholder="Max">
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Sort By</label>
          <select class="form-select" id="mobileSortFilter">
            <option value="newest">Newest</option>
            <option value="price_asc">Price: Low to High</option>
            <option value="price_desc">Price: High to Low</option>
            <option value="popular">Most Popular</option>
            <option value="rating">Top Rated</option>
          </select>
        </div>
        <div class="mb-3">
          <div class="form-check"><input class="form-check-input" type="checkbox" id="mobileInStock"><label class="form-check-label">In Stock Only</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" id="mobileOnSale"><label class="form-check-label">On Sale</label></div>
        </div>
        <button class="btn btn-primary w-100 mb-2" onclick="applyMobileFilters()"><i class="fas fa-filter me-1"></i>Apply Filters</button>
        <button class="btn btn-outline-secondary btn-sm w-100" onclick="resetMobileFilters()">Clear Filters</button>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Products <span id="productCount" class="text-muted fs-6"></span></h4>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-secondary btn-sm active" id="gridBtn" onclick="setView('grid')"><i class="fas fa-th"></i></button>
          <button class="btn btn-outline-secondary btn-sm" id="listBtn" onclick="setView('list')"><i class="fas fa-list"></i></button>
        </div>
      </div>
      <div class="row g-4" id="productsGrid"></div>
      <div id="loading" class="text-center py-5"><div class="spinner-custom mx-auto"></div></div>
      <nav id="pagination" class="mt-4"></nav>
    </div>
  </div>
</div>

<script>
let currentPage = 1;
let currentView = 'grid';
const catLiveMap = { <% categories.forEach(c => { %>'<%= c.slug %>': <%= c.is_live ? 'true' : 'false' %>, <% }) %> };
const catIdMap = { <% categories.forEach(c => { %>'<%= c.slug %>': <%= c.id %>, <% }) %> };

function setView(view) {
  currentView = view;
  document.getElementById('gridBtn').classList.toggle('active', view === 'grid');
  document.getElementById('listBtn').classList.toggle('active', view === 'list');
  loadShopProducts();
}

function toggleBreedBrand() {
  const cat = document.getElementById('categoryFilter').value;
  const isLive = catLiveMap[cat];
  const catId = catIdMap[cat];
  document.getElementById('brandFilterWrap').style.display = isLive ? 'none' : '';
  document.getElementById('breedFilterWrap').style.display = isLive ? '' : 'none';
  document.getElementById('mobileBrandFilterWrap').style.display = isLive ? 'none' : '';
  document.getElementById('mobileBreedFilterWrap').style.display = isLive ? '' : 'none';
  if (!isLive) {
    document.getElementById('breedFilter').value = '';
    document.getElementById('mobileBreedFilter').value = '';
  } else {
    document.getElementById('brandFilter').value = '';
    document.getElementById('mobileBrandFilter').value = '';
    // Show only breeds matching selected category
    document.querySelectorAll('#breedFilter option, #mobileBreedFilter option').forEach(o => {
      if (!o.value) return;
      o.style.display = Number(o.dataset.cat) === Number(catId) ? '' : 'none';
    });
    document.getElementById('breedFilter').value = '';
    document.getElementById('mobileBreedFilter').value = '';
  }
}

function resetFilters() {
  const defaultCat = '<%= selectedCategory || "" %>';
  document.getElementById('searchInput').value = '';
  document.getElementById('mobileSearchInput').value = '';
  document.getElementById('categoryFilter').value = defaultCat;
  document.getElementById('brandFilter').value = '';
  document.getElementById('breedFilter').value = '';
  document.getElementById('minPrice').value = '';
  document.getElementById('maxPrice').value = '';
  document.getElementById('sortFilter').value = 'newest';
  document.getElementById('inStock').checked = false;
  document.getElementById('onSale').checked = false;
  document.getElementById('mobileCategoryFilter').value = defaultCat;
  document.getElementById('mobileBrandFilter').value = '';
  document.getElementById('mobileBreedFilter').value = '';
  document.getElementById('mobileMinPrice').value = '';
  document.getElementById('mobileMaxPrice').value = '';
  document.getElementById('mobileSortFilter').value = 'newest';
  document.getElementById('mobileInStock').checked = false;
  document.getElementById('mobileOnSale').checked = false;
  currentPage = 1;
  toggleBreedBrand();
  loadShopProducts();
}

function mobileSearch() {
  const q = document.getElementById('mobileSearchInput').value;
  document.getElementById('searchInput').value = q;
  currentPage = 1;
  loadShopProducts();
}

function applyMobileFilters() {
  document.getElementById('searchInput').value = document.getElementById('mobileSearchInput').value;
  document.getElementById('categoryFilter').value = document.getElementById('mobileCategoryFilter').value;
  document.getElementById('brandFilter').value = document.getElementById('mobileBrandFilter').value;
  document.getElementById('breedFilter').value = document.getElementById('mobileBreedFilter').value;
  document.getElementById('minPrice').value = document.getElementById('mobileMinPrice').value;
  document.getElementById('maxPrice').value = document.getElementById('mobileMaxPrice').value;
  document.getElementById('sortFilter').value = document.getElementById('mobileSortFilter').value;
  document.getElementById('inStock').checked = document.getElementById('mobileInStock').checked;
  document.getElementById('onSale').checked = document.getElementById('mobileOnSale').checked;
  currentPage = 1;
  toggleBreedBrand();
  const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('filterOffcanvas'));
  if (offcanvas) offcanvas.hide();
  loadShopProducts();
}

function resetMobileFilters() {
  document.getElementById('mobileCategoryFilter').value = '';
  document.getElementById('mobileBrandFilter').value = '';
  document.getElementById('mobileBreedFilter').value = '';
  document.getElementById('mobileMinPrice').value = '';
  document.getElementById('mobileMaxPrice').value = '';
  document.getElementById('mobileSortFilter').value = 'newest';
  document.getElementById('mobileInStock').checked = false;
  document.getElementById('mobileOnSale').checked = false;
  toggleBreedBrand();
}

async function loadShopProducts() {
  const grid = document.getElementById('productsGrid');
  const loading = document.getElementById('loading');
  loading.style.display = 'block';
  grid.innerHTML = '';

  const params = new URLSearchParams();
  const search = document.getElementById('searchInput').value;
  const category = document.getElementById('categoryFilter').value;
  const brand = document.getElementById('brandFilter').value;
  const breed = document.getElementById('breedFilter').value;
  const minPrice = document.getElementById('minPrice').value;
  const maxPrice = document.getElementById('maxPrice').value;
  const sort = document.getElementById('sortFilter').value;
  const inStock = document.getElementById('inStock').checked;

  if (search) params.set('search', search);
  if (category) params.set('category', category);
  if (brand) params.set('brand', brand);
  if (breed) params.set('breed', breed);
  if (minPrice) params.set('min_price', minPrice);
  if (maxPrice) params.set('max_price', maxPrice);
  if (sort) params.set('sort', sort);
  if (inStock) params.set('in_stock', '1');
  const onSale = document.getElementById('onSale').checked;
  if (onSale) params.set('on_sale', '1');
  params.set('page', currentPage);
  params.set('limit', 100);

  try {
    const data = await api(`/products?${params.toString()}`);
    loading.style.display = 'none';
    document.getElementById('productCount').textContent = `(${data.total} products)`;

    if (!data.products.length) {
      grid.innerHTML = '<div class="col-12 text-center py-5"><i class="fas fa-search fa-3x text-muted mb-3"></i><h5>No products found</h5><p class="text-muted">Try adjusting your filters</p></div>';
      return;
    }

    data.products.forEach(p => {
      const discount = p.discount_price > 0 ? Math.round((p.price - p.discount_price) / p.price * 100) : 0;
      const colClass = currentView === 'grid' ? 'col-6 col-md-4' : 'col-12';
      const discPct = discount > 0 ? Math.round((p.price - p.discount_price) / p.price * 100) : 0;
      const badges = [];
      if (discount > 0) badges.push(`<span class="badge badge-sale">-${discPct}%</span>`);
      if (p.is_new_arrival) badges.push(`<span class="badge badge-new">New</span>`);
      if (p.is_featured) badges.push(`<span class="badge badge-featured">Featured</span>`);
      grid.innerHTML += `
        <div class="${colClass} fade-in">
          <div class="product-card position-relative ${currentView === 'list' ? 'd-flex flex-row' : ''}">
            ${badges.length ? `<div class="product-badge">${badges.join('')}</div>` : ''}
            <div class="${currentView === 'list' ? 'flex-shrink-0' : ''}" style="position:relative;${currentView === 'list' ? 'width:200px;min-width:200px' : ''}">
              <a href="/product/${btoa(String(p.id)).replace(/[+/=]/g, c => ({'+':'-','/':'_','=':''})[c])}">
                <div class="card-img-wrapper" style="${currentView === 'list' ? 'height:200px' : ''}">
                  <img src="${p.primary_image || '/images/no-image.png'}" class="card-img-top" alt="${p.name}" loading="lazy" onerror="this.style.display='none'">
                </div>
              </a>
              <button class="btn btn-sm wishlist-overlay" onclick="toggleWishlist(${p.id})" data-wishlist="${p.id}" title="Wishlist"><i class="far fa-heart"></i></button>
            </div>
            <div class="card-body d-flex flex-column">
              ${p.category_name ? `<small class="card-category">${p.category_name}</small>` : ''}
              ${p.is_live ? (p.breed_name ? `<small class="text-muted"><i class="fas fa-paw me-1"></i>${p.breed_name}</small>` : '') : (p.brand_name ? `<small class="text-muted">${p.brand_name}</small>` : '')}
              <a href="/product/${btoa(String(p.id)).replace(/[+/=]/g, c => ({'+':'-','/':'_','=':''})[c])}" class="text-decoration-none">
                <h6 class="card-title">${p.name}</h6>
              </a>
              <div class="product-rating">
                <span class="stars">${'★'.repeat(Math.round(p.rating || 0))}${'☆'.repeat(5 - Math.round(p.rating || 0))}</span>
                <span class="count">(${p.review_count || 0})</span>
              </div>
              <div class="product-price mt-auto">
                ₹${(p.discount_price > 0 ? p.discount_price : p.price).toLocaleString()}
                ${p.discount_price > 0 ? `<span class="old-price">₹${p.price.toLocaleString()}</span><span class="discount-tag">-${discPct}%</span>` : ''}
              </div>
              <div class="btn-group mt-2">
                <button class="btn btn-primary btn-sm" onclick="addToCart(${p.id}, 1, this)"><i class="fas fa-cart-plus me-1"></i>Add</button>
                <button class="btn btn-success btn-sm" onclick="buyNow(${p.id}, 1)"><i class="fas fa-bolt me-1"></i>Buy Now</button>
                <button class="btn btn-outline-primary btn-sm" onclick="window.location.href='/product/${btoa(String(p.id)).replace(/[+/=]/g, c => ({'+':'-','/':'_','=':''})[c])}'"><i class="fas fa-eye me-1"></i>View</button>
              </div>
            </div>
          </div>
        </div>`;
    });

    initScrollAnimations();

    // Pagination
    if (data.pages > 1) {
      let pagHtml = '<ul class="pagination justify-content-center">';
      for (let i = 1; i <= data.pages; i++) {
        pagHtml += `<li class="page-item ${i === data.page ? 'active' : ''}"><a class="page-link" href="#" onclick="goToPage(${i})">${i}</a></li>`;
      }
      pagHtml += '</ul>';
      document.getElementById('pagination').innerHTML = pagHtml;
    } else {
      document.getElementById('pagination').innerHTML = '';
    }
  } catch (e) {
    loading.style.display = 'none';
    grid.innerHTML = '<div class="col-12 text-center py-5"><p class="text-muted">Error loading products</p></div>';
  }
}

function goToPage(page) {
  currentPage = page;
  loadShopProducts();
  window.scrollTo(0, 0);
}

(function init() {
  if (typeof api !== 'function') return setTimeout(init, 50);
  const params = new URLSearchParams(window.location.search);
  const searchVal = params.get('search');
  const catVal = params.get('category') || '<%= selectedCategory %>';
  const brandVal = params.get('brand');
  const breedVal = params.get('breed');
  if (searchVal) {
    document.getElementById('searchInput').value = searchVal;
    document.getElementById('mobileSearchInput').value = searchVal;
  }
  if (catVal) {
    document.getElementById('categoryFilter').value = catVal;
    document.getElementById('mobileCategoryFilter').value = catVal;
  }
  if (brandVal) {
    document.getElementById('brandFilter').value = brandVal;
    document.getElementById('mobileBrandFilter').value = brandVal;
  }
  if (breedVal) {
    document.getElementById('breedFilter').value = breedVal;
    document.getElementById('mobileBreedFilter').value = breedVal;
  }
  document.getElementById('categoryFilter').addEventListener('change', function() {
    document.getElementById('mobileCategoryFilter').value = this.value;
    toggleBreedBrand();
  });
  document.getElementById('mobileCategoryFilter').addEventListener('change', function() {
    document.getElementById('categoryFilter').value = this.value;
    toggleBreedBrand();
  });
  toggleBreedBrand();
  loadShopProducts();
  if (isLoggedIn()) {
    api('/wishlist').then(d => {
      window._wishlistIds = new Set((d.items || []).map(i => i.product_id));
      window._wishlistIds.forEach(id => {
        document.querySelectorAll(`[data-wishlist="${id}"]`).forEach(btn => {
          btn.innerHTML = '<i class="fas fa-heart text-danger"></i>';
          btn.classList.add('wishlist-active');
        });
      });
    }).catch(() => {});
  }
})();
</script>

<%- include('partials/footer') %>
