<%- include('partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="glass-card p-4">
        <div class="text-center mb-4">
          <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--aqua));display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
            <i class="fas fa-fish" style="color:#fff;font-size:2rem"></i>
          </div>
          <h3 class="fw-bold">Welcome Back</h3>
          <p class="text-muted">Login to your account</p>
        </div>
        <form id="loginForm">
          <div class="mb-3">
            <label class="form-label">Email or Phone</label>
            <input type="text" class="form-control" id="login" required placeholder="Enter email or phone">
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <div class="input-group">
              <input type="password" class="form-control" id="password" required>
              <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 btn-lg">Login</button>
        </form>
        <div class="text-center my-3">
          <div class="d-flex align-items-center">
            <hr class="flex-grow-1">
            <span class="mx-2 text-muted">OR</span>
            <hr class="flex-grow-1">
          </div>
        </div>
        <% if (googleClientId) { %>
        <div id="g_id_onload"
             data-client_id="<%= googleClientId %>"
             data-callback="handleGoogleCredential">
        </div>
        <div class="g_id_signin" data-type="standard" data-size="large" data-theme="outline" data-text="sign_in_with" data-shape="rectangular" data-width="300" style="display:flex;justify-content:center;"></div>
        <% } else { %>
        <button class="btn btn-outline-danger w-100 btn-lg" disabled title="Google Sign-In not configured">
          <i class="fab fa-google me-2"></i> Google Sign-In (Not Configured)
        </button>
        <% } %>
        <div class="text-center mt-3">
          <p class="mb-0">Don't have an account? <a href="/register" class="text-primary fw-semibold">Register</a></p>
        </div>
      </div>
    </div>
  </div>
</div>
<% if (googleClientId) { %>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<% } %>
<script>
function handleGoogleCredential(response) {
  fetch('/api/auth/google', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ credential: response.credential })
  })
  .then(res => res.json())
  .then(data => {
    if (data.error) throw new Error(data.error);
    setAuth(data);
    showToast('Login successful!');
    setTimeout(() => window.location.href = data.user.role === 'admin' ? '/admin' : '/', 500);
  })
  .catch(e => showToast(e.message, 'error'));
}

document.getElementById('togglePassword').addEventListener('click', function() {
  const input = document.getElementById('password');
  const icon = this.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'fas fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fas fa-eye';
  }
});

document.getElementById('loginForm').addEventListener('submit', async(e) => {
  e.preventDefault();
  try {
    const data = await api('/auth/login', { method:'POST', body: JSON.stringify({ login: document.getElementById('login').value, password: document.getElementById('password').value }) });
    setAuth(data);
    showToast('Login successful!');
    setTimeout(() => window.location.href = data.user.role === 'admin' ? '/admin' : '/', 500);
  } catch(e) { showToast(e.message, 'error'); }
});
</script>
<%- include('partials/footer') %>
