<%- include('partials/header') %>
<div class="container py-4">
  <a href="/orders" class="btn btn-outline-secondary btn-sm mb-3"><i class="fas fa-arrow-left me-1"></i>Back to Orders</a>
  <div id="orderContent"></div>
</div>

<!-- Address Edit Modal -->
<div class="modal fade" id="addressModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Update Shipping Address</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="addressForm">
          <div class="row g-2 mb-2">
            <div class="col-6"><label class="form-label">Name</label><input type="text" class="form-control" id="aName"></div>
            <div class="col-6"><label class="form-label">Phone</label><input type="tel" class="form-control" id="aPhone"></div>
          </div>
          <div class="mb-2"><label class="form-label">WhatsApp</label><input type="tel" class="form-control" id="aWhatsapp"></div>
          <div class="mb-2"><label class="form-label">Address</label><textarea class="form-control" id="aAddress" rows="2"></textarea></div>
          <div class="row g-2 mb-2">
            <div class="col-5"><label class="form-label">City</label><input type="text" class="form-control" id="aCity"></div>
            <div class="col-4"><label class="form-label">State</label><input type="text" class="form-control" id="aState"></div>
            <div class="col-3"><label class="form-label">Pincode</label><input type="text" class="form-control" id="aPincode"></div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="saveAddress()">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
let order = null;

async function loadOrder() {
  const container = document.getElementById('orderContent');
  if (!isLoggedIn()) { container.innerHTML = '<p>Please <a href="/login">login</a> to view order.</p>'; return; }
  try {
    const data = await api('/orders');
    order = data.orders.find(o => o.order_number === '<%= orderNumber %>');
    if (!order) { container.innerHTML = '<p class="text-muted">Order not found.</p>'; return; }
    const canModify = order.order_status === 'pending';
    const statusColor = { delivered:'success', cancelled:'danger', confirmed:'info', processing:'warning', dispatched:'primary', pending:'secondary' };
    container.innerHTML = `
      <div class="glass-card p-3 mb-3">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
              <h4 class="fw-bold mb-1">Order #${order.order_number}</h4>
              <small class="text-muted">${new Date(order.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })}</small>
            </div>
            <span class="badge bg-${statusColor[order.order_status] || 'secondary'} fs-6">${order.order_status}</span>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-user me-2"></i>Customer</h6>
              <p class="mb-1">${order.customer_name}<br>${order.customer_phone}${order.customer_whatsapp ? ' | ' + order.customer_whatsapp : ''}<br>${order.customer_email || ''}</p>
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-map-marker-alt me-2"></i>Shipping Address</h6>
              <p class="mb-1">${order.shipping_address}<br>${order.shipping_city}, ${order.shipping_state} - ${order.shipping_pincode}</p>
              ${canModify ? '<button class="btn btn-sm btn-outline-primary" onclick="showAddressModal()"><i class="fas fa-edit me-1"></i>Edit Address</button>' : ''}
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-credit-card me-2"></i>Payment</h6>
              <p class="mb-1">${order.payment_method.toUpperCase()} ${order.payment_status === 'paid' ? '<span class="badge bg-success">Paid</span>' : '<span class="badge bg-warning text-dark">' + order.payment_status + '</span>'}</p>
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-tag me-2"></i>Total</h6>
              <p class="mb-1 fw-bold fs-5">₹${order.total.toLocaleString()}</p>
              <small class="text-muted">Subtotal: ₹${order.subtotal.toLocaleString()}${order.discount > 0 ? ' | Discount: -₹' + order.discount.toLocaleString() : ''} | Delivery: ${order.shipping_charge === 0 ? 'Free' : '₹' + order.shipping_charge}</small>
            </div>
          </div>
          ${order.notes ? '<div class="mt-2"><small class="text-muted"><strong>Notes:</strong> ' + order.notes + '</small></div>' : ''}
        </div>
      </div>
      <div class="glass-card p-3 mb-3">
          <h6 class="fw-bold mb-3"><i class="fas fa-box me-2"></i>Items</h6>
          <div id="orderItems"></div>
      </div>
      ${canModify ? '<button class="btn btn-danger btn-lg w-100" onclick="cancelOrder()"><i class="fas fa-ban me-2"></i>Cancel Order</button>' : '<p class="text-muted text-center">This order can no longer be modified.</p>'}
    `;
    loadItems();
  } catch(e) { container.innerHTML = '<p class="text-muted">Error loading order.</p>'; }
}

async function loadItems() {
  try {
    const data = await api('/orders/' + order.id);
    const items = data.order.items || [];
    document.getElementById('orderItems').innerHTML = items.map(i => `
      <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
          <img src="${i.product_image || '/images/no-image.png'}" style="width:50px;height:50px;object-fit:cover;border-radius:8px" onerror="this.style.display='none'">
          <div><small class="fw-semibold">${i.product_name}</small><br><small class="text-muted">x${i.quantity} @ ₹${i.price.toLocaleString()}</small></div>
        </div>
        <strong>₹${i.total.toLocaleString()}</strong>
      </div>`).join('');
  } catch(e) {}
}

function showAddressModal() {
  document.getElementById('aName').value = order.customer_name || '';
  document.getElementById('aPhone').value = order.customer_phone || '';
  document.getElementById('aWhatsapp').value = order.customer_whatsapp || '';
  document.getElementById('aAddress').value = order.shipping_address || '';
  document.getElementById('aCity').value = order.shipping_city || '';
  document.getElementById('aState').value = order.shipping_state || '';
  document.getElementById('aPincode').value = order.shipping_pincode || '';
  new bootstrap.Modal(document.getElementById('addressModal')).show();
}

async function saveAddress() {
  const body = {
    customer_name: document.getElementById('aName').value,
    customer_phone: document.getElementById('aPhone').value,
    customer_whatsapp: document.getElementById('aWhatsapp').value,
    shipping_address: document.getElementById('aAddress').value,
    shipping_city: document.getElementById('aCity').value,
    shipping_state: document.getElementById('aState').value,
    shipping_pincode: document.getElementById('aPincode').value
  };
  if (!body.shipping_address || !body.shipping_city || !body.shipping_state || !body.shipping_pincode) {
    showToast('All address fields required', 'error'); return;
  }
  try {
    await api(`/orders/shipping/${order.order_number}`, { method: 'PUT', body: JSON.stringify(body) });
    bootstrap.Modal.getInstance(document.getElementById('addressModal')).hide();
    showToast('Address updated!');
    loadOrder();
  } catch(e) { showToast(e.message, 'error'); }
}

async function cancelOrder() {
  if (!confirm('Are you sure you want to cancel this order?')) return;
  try {
    await api(`/orders/cancel/${order.order_number}`, { method: 'PUT' });
    showToast('Order cancelled');
    loadOrder();
  } catch(e) { showToast(e.message, 'error'); }
}

document.addEventListener('DOMContentLoaded', loadOrder);
</script>
<%- include('partials/footer') %>