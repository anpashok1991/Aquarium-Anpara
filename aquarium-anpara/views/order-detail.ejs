<%- include('partials/header') %>
<div class="container py-4">
  <a href="/orders" class="btn btn-outline-secondary btn-sm mb-3"><i class="fas fa-arrow-left me-1"></i>Back to Orders</a>
  <div id="orderContent"></div>
</div>

<!-- Address Edit Modal -->
<div class="modal fade" id="addressModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Update Shipping Address</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="addressForm">
          <div class="row g-2 mb-2">
            <div class="col-6"><label class="form-label">Name</label><input type="text" class="form-control" id="aName"></div>
            <div class="col-6"><label class="form-label">Phone</label><input type="tel" class="form-control" id="aPhone"></div>
          </div>
          <div class="mb-2"><label class="form-label">WhatsApp</label><input type="tel" class="form-control" id="aWhatsapp"></div>
          <div class="mb-2"><label class="form-label">Address</label><textarea class="form-control" id="aAddress" rows="2"></textarea></div>
          <div class="row g-2 mb-2">
            <div class="col-5"><label class="form-label">City</label><input type="text" class="form-control" id="aCity"></div>
            <div class="col-4"><label class="form-label">State</label><input type="text" class="form-control" id="aState"></div>
            <div class="col-3"><label class="form-label">Pincode</label><input type="text" class="form-control" id="aPincode"></div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="saveAddress()">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
let order = null;

async function loadOrder() {
  const container = document.getElementById('orderContent');
  if (!isLoggedIn()) { container.innerHTML = '<p>Please <a href="/login">login</a> to view order.</p>'; return; }
  try {
    const data = await api('/orders');
    order = data.orders.find(o => o.order_number === '<%= orderNumber %>');
    if (!order) { container.innerHTML = '<p class="text-muted">Order not found.</p>'; return; }
    const canModify = order.order_status === 'pending';
    const statusColor = { delivered:'success', cancelled:'danger', confirmed:'info', processing:'warning', dispatched:'primary', pending:'secondary' };
    container.innerHTML = `
      <div class="glass-card p-3 mb-3">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
              <h4 class="fw-bold mb-1">Order #${order.order_number}</h4>
              <small class="text-muted">${new Date(order.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })}</small>
            </div>
            <span class="badge bg-${statusColor[order.order_status] || 'secondary'} fs-6">${order.order_status}</span>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-user me-2"></i>Customer</h6>
              <p class="mb-1">${order.customer_name}<br>${order.customer_phone}${order.customer_whatsapp ? ' | ' + order.customer_whatsapp : ''}<br>${order.customer_email || ''}</p>
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-map-marker-alt me-2"></i>Shipping Address</h6>
              <p class="mb-1">${order.shipping_address}<br>${order.shipping_city}, ${order.shipping_state} - ${order.shipping_pincode}</p>
              ${canModify ? '<button class="btn btn-sm btn-outline-primary" onclick="showAddressModal()"><i class="fas fa-edit me-1"></i>Edit Address</button>' : ''}
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-credit-card me-2"></i>Payment</h6>
              <p class="mb-1">${order.payment_method.toUpperCase()} ${order.payment_status === 'paid' ? '<span class="badge bg-success">Paid</span>' : '<span class="badge bg-warning text-dark">' + order.payment_status + '</span>'}</p>
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold"><i class="fas fa-tag me-2"></i>Total</h6>
              ${order.order_status === 'delivered' || order.order_status === 'completed' ? `<div class="mb-2"><a href="/invoice/${order.order_number}" target="_blank" class="btn btn-outline-primary btn-sm"><i class="fas fa-receipt me-1"></i>View Invoice</a></div>` : ''}
              <p class="mb-1 fw-bold fs-5">₹${order.total.toLocaleString()}</p>
              <small class="text-muted">Subtotal: ₹${order.subtotal.toLocaleString()}${order.discount > 0 ? ' | Discount: -₹' + order.discount.toLocaleString() : ''} | Delivery: ${order.shipping_charge === 0 ? 'Free' : '₹' + order.shipping_charge}</small>
            </div>
          </div>
          ${order.notes ? '<div class="mt-2"><small class="text-muted"><strong>Notes:</strong> ' + order.notes + '</small></div>' : ''}
        </div>
      </div>
      <div class="glass-card p-3 mb-3">
          <h6 class="fw-bold mb-3"><i class="fas fa-box me-2"></i>Items</h6>
          <div id="orderItems"></div>
      </div>
      ${canModify ? '<button class="btn btn-danger btn-lg w-100" onclick="cancelOrder()"><i class="fas fa-ban me-2"></i>Cancel Order</button>' : ''}
      ${order.order_status === 'delivered' || order.order_status === 'completed' ? '<div class="mt-4"><h5 class="fw-bold mb-3"><i class="fas fa-star me-2"></i>Write a Review</h5><div id="reviewSection"></div></div>' : '<p class="text-muted text-center mt-3">This order can no longer be modified.</p>'}
    `;
    loadItems();
    if (order.order_status === 'delivered' || order.order_status === 'completed') {
      loadReviewForm();
    }
  } catch(e) { container.innerHTML = '<p class="text-muted">Error loading order.</p>'; }
}

async function loadItems() {
  try {
    const data = await api('/orders/' + order.id);
    const items = data.order.items || [];
    document.getElementById('orderItems').innerHTML = items.map(i => `
      <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom" id="item-${i.product_id}">
        <div class="d-flex align-items-center gap-2">
          <img src="${i.product_image || '/images/no-image.png'}" style="width:50px;height:50px;object-fit:cover;border-radius:8px" onerror="this.style.display='none'">
          <div><small class="fw-semibold">${i.product_name}</small><br><small class="text-muted">x${i.quantity} @ ₹${i.price.toLocaleString()}</small></div>
        </div>
        <strong>₹${i.total.toLocaleString()}</strong>
      </div>`).join('');
  } catch(e) {}
}

function getReviewForm(productId, productName, existing) {
  if (existing) {
    const imgs = existing.images || [];
    const starHtml = [1,2,3,4,5].map(s =>
      `<i class="fas fa-star ${s <= existing.rating ? 'text-warning' : 'text-muted'}" data-star="${s}" style="cursor:pointer;font-size:1.3rem;margin-right:2px" onclick="setRating(${productId},${s})"></i>`
    ).join('');
    window._existingReviewImages = window._existingReviewImages || {};
    window._existingReviewImages[productId] = (imgs || []).slice();
    return `
      <div class="border-top pt-3 mb-3" id="reviewForm-${productId}" data-review-id="${existing.id}">
        <div class="mb-2 d-flex align-items-center gap-2">
          <img src="/images/no-image.png" style="width:32px;height:32px;border-radius:50%;object-fit:cover" onerror="this.style.display='none'">
          <strong>${productName}</strong>
          <span class="badge bg-success ms-2"><i class="fas fa-check me-1"></i>Reviewed</span>
        </div>
        <div class="mb-2">
          <label class="form-label small">Rating</label>
          <div class="star-rating" id="stars-${productId}">${starHtml}</div>
        </div>
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm" id="reviewTitle-${productId}" placeholder="Review title (optional)" value="${existing.title || ''}">
        </div>
        <div class="mb-2">
          <textarea class="form-control form-control-sm" id="reviewComment-${productId}" rows="2" placeholder="Share your experience with this product">${existing.comment || ''}</textarea>
        </div>
        <div class="mb-2">
          <div id="existingImages-${productId}" class="d-flex gap-2 mb-2 flex-wrap">
            ${imgs.map((img, i) => `<div style="position:relative;display:inline-block" data-img-index="${i}"><img src="${img}" style="height:50px;width:50px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6"><button type="button" style="position:absolute;top:-4px;right:-4px;background:#dc3545;color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:10px;line-height:18px;text-align:center;cursor:pointer;padding:0" onclick="removeExistingImage(${productId},${i})">&times;</button></div>`).join('')}
          </div>
          <input type="file" class="form-control form-control-sm" accept="image/*" multiple onchange="handleReviewFiles(this, ${productId})">
          <div id="reviewImagePreview-${productId}" class="mt-1"></div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="updateReview(${productId})"><i class="fas fa-save me-1"></i>Update Review</button>
      </div>`;
  }
  return `
    <div class="border-top pt-3 mb-3" id="reviewForm-${productId}">
      <div class="mb-2 d-flex align-items-center gap-2">
        <img src="/images/no-image.png" style="width:32px;height:32px;border-radius:50%;object-fit:cover" onerror="this.style.display='none'">
        <strong>${productName}</strong>
      </div>
      <div class="mb-2">
        <label class="form-label small">Rating</label>
        <div class="star-rating" id="stars-${productId}">
          ${[1,2,3,4,5].map(s => `<i class="fas fa-star text-muted" data-star="${s}" style="cursor:pointer;font-size:1.3rem;margin-right:2px" onclick="setRating(${productId},${s})"></i>`).join('')}
        </div>
      </div>
      <div class="mb-2">
        <input type="text" class="form-control form-control-sm" id="reviewTitle-${productId}" placeholder="Review title (optional)">
      </div>
      <div class="mb-2">
        <textarea class="form-control form-control-sm" id="reviewComment-${productId}" rows="2" placeholder="Share your experience with this product"></textarea>
      </div>
      <div class="mb-2">
        <input type="file" class="form-control form-control-sm" accept="image/*" multiple onchange="handleReviewFiles(this, ${productId})">
        <div id="reviewImagePreview-${productId}" class="mt-1"></div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="submitReview(${productId})"><i class="fas fa-paper-plane me-1"></i>Submit Review</button>
    </div>`;
}

function removeExistingImage(productId, index) {
  if (!window._existingReviewImages?.[productId]) return;
  window._existingReviewImages[productId].splice(index, 1);
  const container = document.getElementById(`existingImages-${productId}`);
  if (!container) return;
  const imgs = container.querySelectorAll('[data-img-index]');
  let removed = 0;
  imgs.forEach(el => {
    const idx = parseInt(el.dataset.imgIndex);
    if (idx === index) { el.remove(); removed = 1; }
    else if (idx > index) el.dataset.imgIndex = idx - removed;
  });
}

function handleReviewFiles(input, productId) {
  // Store files per product
  if (!window._reviewFiles) window._reviewFiles = {};
  if (!window._reviewFiles[productId]) window._reviewFiles[productId] = [];
  Array.from(input.files).forEach(f => {
    const reader = new FileReader();
    reader.onload = e => {
      window._reviewFiles[productId].push(e.target.result);
      renderProductReviewPreview(productId);
    };
    reader.readAsDataURL(f);
  });
  input.value = '';
}

function renderProductReviewPreview(productId) {
  const container = document.getElementById(`reviewImagePreview-${productId}`);
  if (!container) return;
  const imgs = window._reviewFiles[productId] || [];
  container.innerHTML = imgs.map((img, i) =>
    `<div style="position:relative;display:inline-block;margin:4px">
      <img src="${img}" style="height:50px;width:50px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6">
      <button type="button" style="position:absolute;top:-4px;right:-4px;background:#dc3545;color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:10px;line-height:18px;text-align:center;cursor:pointer;padding:0" onclick="removeProductReviewImage(${productId},${i})">&times;</button>
    </div>`
  ).join('');
}

function removeProductReviewImage(productId, index) {
  if (window._reviewFiles[productId]) {
    window._reviewFiles[productId].splice(index, 1);
    renderProductReviewPreview(productId);
  }
}

let currentRatings = {};

function setRating(productId, star) {
  currentRatings[productId] = star;
  const container = document.getElementById(`stars-${productId}`);
  if (!container) return;
  container.querySelectorAll('.fa-star').forEach(el => {
    const s = parseInt(el.dataset.star);
    el.classList.toggle('text-muted', s > star);
    el.classList.toggle('text-warning', s <= star);
  });
}

async function submitReview(productId) {
  const rating = currentRatings[productId];
  if (!rating) { showToast('Please select a rating', 'error'); return; }
  const title = document.getElementById(`reviewTitle-${productId}`).value;
  const comment = document.getElementById(`reviewComment-${productId}`).value;
  const images = window._reviewFiles?.[productId] || [];
  try {
    const body = { product_id: productId, rating, title, comment, images: images.length ? images : undefined };
    await api('/reviews', { method: 'POST', body: JSON.stringify(body) });
    showToast('Review submitted!');
    document.getElementById(`reviewForm-${productId}`).innerHTML = '<p class="text-success small"><i class="fas fa-check-circle me-1"></i>Review submitted. Thank you!</p>';
  } catch(e) { showToast(e.message, 'error'); }
}

async function updateReview(productId) {
  const form = document.getElementById(`reviewForm-${productId}`);
  const reviewId = form.dataset.reviewId;
  const rating = currentRatings[productId];
  if (!rating) { showToast('Please select a rating', 'error'); return; }
  const title = document.getElementById(`reviewTitle-${productId}`).value;
  const comment = document.getElementById(`reviewComment-${productId}`).value;
  const existingImgs = window._existingReviewImages?.[productId] || [];
  const newImgs = window._reviewFiles?.[productId] || [];
  const images = [...existingImgs, ...newImgs];
  try {
    await api(`/reviews/${reviewId}`, { method: 'PUT', body: JSON.stringify({ rating, title, comment, images }) });
    showToast('Review updated!');
    form.innerHTML = '<p class="text-success small"><i class="fas fa-check-circle me-1"></i>Review updated successfully.</p>';
  } catch(e) { showToast(e.message, 'error'); }
}

async function loadReviewForm() {
  try {
    const data = await api('/orders/' + order.id);
    const items = data.order.items || [];
    const container = document.getElementById('reviewSection');
    if (!container) return;
    if (!items.length) { container.innerHTML = ''; return; }
    const productIds = items.map(i => i.product_id);
    let existingMap = {};
    try {
      const reviewData = await api('/reviews/my?product_ids=' + productIds.join(','));
      (reviewData.reviews || []).forEach(r => { existingMap[r.product_id] = r; });
    } catch(e) {}
    container.innerHTML = '<p class="text-muted small mb-3">Rate the products you received:</p>' +
      items.map(i => getReviewForm(i.product_id, i.product_name, existingMap[i.product_id])).join('');
  } catch(e) {}
}

function showAddressModal() {
  document.getElementById('aName').value = order.customer_name || '';
  document.getElementById('aPhone').value = order.customer_phone || '';
  document.getElementById('aWhatsapp').value = order.customer_whatsapp || '';
  document.getElementById('aAddress').value = order.shipping_address || '';
  document.getElementById('aCity').value = order.shipping_city || '';
  document.getElementById('aState').value = order.shipping_state || '';
  document.getElementById('aPincode').value = order.shipping_pincode || '';
  new bootstrap.Modal(document.getElementById('addressModal')).show();
}

async function saveAddress() {
  const body = {
    customer_name: document.getElementById('aName').value,
    customer_phone: document.getElementById('aPhone').value,
    customer_whatsapp: document.getElementById('aWhatsapp').value,
    shipping_address: document.getElementById('aAddress').value,
    shipping_city: document.getElementById('aCity').value,
    shipping_state: document.getElementById('aState').value,
    shipping_pincode: document.getElementById('aPincode').value
  };
  if (!body.shipping_address || !body.shipping_city || !body.shipping_state || !body.shipping_pincode) {
    showToast('All address fields required', 'error'); return;
  }
  try {
    await api(`/orders/shipping/${order.order_number}`, { method: 'PUT', body: JSON.stringify(body) });
    bootstrap.Modal.getInstance(document.getElementById('addressModal')).hide();
    showToast('Address updated!');
    loadOrder();
  } catch(e) { showToast(e.message, 'error'); }
}

async function cancelOrder() {
  if (!confirm('Are you sure you want to cancel this order?')) return;
  try {
    await api(`/orders/cancel/${order.order_number}`, { method: 'PUT' });
    showToast('Order cancelled');
    loadOrder();
  } catch(e) { showToast(e.message, 'error'); }
}

document.addEventListener('DOMContentLoaded', loadOrder);
</script>
<%- include('partials/footer') %>