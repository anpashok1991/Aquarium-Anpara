<%- include('partials/header') %>
<section class="hero-section" style="min-height:40vh">
  <div class="container text-center">
    <h1>About <%= shopName %></h1>
    <p class="lead">Your trusted partner in pet care since 2019</p>
  </div>
</section>
<section class="section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6"><img src="/images/about.png" class="img-fluid rounded shadow" alt="About Us" onerror="this.src='/images/no-image.png'"></div>
      <div class="col-lg-6">
        <h2 class="fw-bold">Our Story</h2>
        <p class="text-muted">Started with a passion for aquariums and pets, <%= shopName %> has grown into a complete pet and aquarium destination. We provide premium quality fishes, pets, food, accessories, and expert setup services.</p>
        <div class="row g-4 mt-4">
          <div class="col-6"><div class="text-center p-3 bg-light rounded"><h4 class="text-primary fw-bold">5+</h4><small>Years Experience</small></div></div>
          <div class="col-6"><div class="text-center p-3 bg-light rounded"><h4 class="text-primary fw-bold">2000+</h4><small>Happy Customers</small></div></div>
          <div class="col-6"><div class="text-center p-3 bg-light rounded"><h4 class="text-primary fw-bold">500+</h4><small>Products</small></div></div>
          <div class="col-6"><div class="text-center p-3 bg-light rounded"><h4 class="text-primary fw-bold">50+</h4><small>Fish Species</small></div></div>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section bg-white">
  <div class="container text-center">
    <h2 class="fw-bold mb-4">Our Mission & Vision</h2>
    <div class="row g-4">
      <div class="col-md-6"><div class="p-4"><i class="fas fa-bullseyee fa-3x text-primary mb-3"></i><h4>Mission</h4><p class="text-muted">To provide the highest quality pet products and services while ensuring the health and happiness of every pet we serve.</p></div></div>
      <div class="col-md-6"><div class="p-4"><i class="fas fa-eye fa-3x text-primary mb-3"></i><h4>Vision</h4><p class="text-muted">To become the most trusted and comprehensive pet care destination, known for quality, care, and customer satisfaction.</p></div></div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>