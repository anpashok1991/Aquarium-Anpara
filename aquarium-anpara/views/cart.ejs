<%- include('partials/header') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>Shopping Cart</h2>
  <div class="row g-4">
    <div class="col-lg-8">
      <div id="cartItems"></div>
      <div id="emptyCart" class="text-center py-5" style="display:none">
        <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
        <h4>Your cart is empty</h4>
        <p class="text-muted">Start adding products to your cart</p>
        <a href="/shop" class="btn btn-primary">Continue Shopping</a>
      </div>

      <!-- Saved for Later -->
      <div id="savedSection" class="mt-4" style="display:none">
        <h5 class="fw-bold mb-3"><i class="fas fa-clock me-2 text-muted"></i>Saved for Later</h5>
        <div id="savedItems"></div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="glass-card p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-receipt text-primary me-2"></i>Order Summary</h5>
        <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span id="subtotal">₹0</span></div>
        <div class="d-flex justify-content-between mb-2"><span>Delivery</span><span id="delivery" class="text-success">Free</span></div>
        <div class="d-flex justify-content-between mb-3"><span>Discount</span><span id="discount" class="text-danger">-₹0</span></div>
        <hr>
        <div class="d-flex justify-content-between fw-bold fs-5 mb-3"><span>Total</span><span id="total">₹0</span></div>

        <div class="mb-3">
          <div class="input-group">
            <input type="text" class="form-control" id="couponCode" placeholder="Coupon code">
            <button class="btn btn-outline-primary" onclick="applyCoupon()">Apply</button>
          </div>
          <small id="couponMsg" class="text-muted"></small>
        </div>

        <a href="/checkout" class="btn btn-primary w-100 btn-lg" id="checkoutBtn">
          <i class="fas fa-lock me-2"></i>Proceed to Checkout
        </a>
        <a href="/shop" class="btn btn-outline-secondary w-100 mt-2"><i class="fas fa-arrow-left me-2"></i>Continue Shopping</a>
      </div>
    </div>
  </div>
</div>

<script>
let cartData = { items: [], subtotal: 0 };
let appliedCoupon = null;
let savedItems = [];

async function loadCart() {
  try {
    cartData = await api('/cart');
    const saved = localStorage.getItem('coupon');
    if (saved && cartData.items.length) {
      try { appliedCoupon = JSON.parse(saved); } catch { localStorage.removeItem('coupon'); }
    } else {
      localStorage.removeItem('coupon');
    }
    renderCart();
    loadSavedItems();
  } catch (e) { console.error(e); }
}

function renderCart() {
  const container = document.getElementById('cartItems');
  const empty = document.getElementById('emptyCart');
  if (!cartData.items.length) { container.innerHTML = ''; empty.style.display = 'block'; document.getElementById('checkoutBtn').style.display = 'none'; return; }
  empty.style.display = 'none';
  document.getElementById('checkoutBtn').style.display = '';

  container.innerHTML = cartData.items.map(item => `
    <div class="cart-item">
      <img src="${item.image || '/images/no-image.png'}" alt="${item.name}" onerror="this.style.display='none'">
      <div class="flex-grow-1">
        <h6 class="mb-1"><a href="/product/${btoa(String(item.id)).replace(/[+/=]/g, c => ({'+':'-','/':'_','=':''})[c])}" class="text-decoration-none">${item.name}</a></h6>
        <span class="text-primary fw-bold">₹${(item.unit_price || item.price).toLocaleString()}</span>
        ${item.discount_price > 0 ? `<span class="text-muted text-decoration-line-through ms-2">₹${item.price.toLocaleString()}</span>` : ''}
        ${item.stock_quantity <= 5 ? `<span class="badge bg-warning text-dark ms-2">Only ${item.stock_quantity} left</span>` : ''}
      </div>
      <div class="d-flex align-items-center gap-1">
        <button class="btn btn-outline-secondary btn-sm" onclick="updateCartItem(${item.id}, ${item.quantity - 1})">−</button>
        <input type="number" class="form-control form-control-sm text-center" style="width:55px" value="${item.quantity}" min="1" max="${item.stock_quantity}" onchange="updateCartItem(${item.id}, +this.value || 1)" onfocus="this.select()">
        <button class="btn btn-outline-secondary btn-sm" onclick="updateCartItem(${item.id}, ${item.quantity + 1})">+</button>
      </div>
      <div class="text-end" style="min-width:90px">
        <strong>₹${(item.item_total || item.unit_price * item.quantity).toLocaleString()}</strong>
        <br><button class="btn btn-link text-muted btn-sm p-0" onclick="saveForLater(${item.id})"><small>Save for later</small></button>
        <br><button class="btn btn-link text-danger btn-sm p-0" onclick="removeFromCart(${item.id})"><small>Remove</small></button>
      </div>
    </div>
  `).join('');

  updateSummary();
}

function updateSummary() {
  document.getElementById('subtotal').textContent = '₹' + cartData.subtotal.toLocaleString();
  const delivery = cartData.subtotal >= 500 ? 0 : 50;
  document.getElementById('delivery').textContent = delivery === 0 ? 'Free' : '₹' + delivery;
  document.getElementById('delivery').className = delivery === 0 ? 'text-success' : '';
  let discount = 0;
  if (appliedCoupon) { discount = appliedCoupon.discount; document.getElementById('discount').textContent = '-₹' + discount.toFixed(0); }
  document.getElementById('total').textContent = '₹' + (cartData.subtotal - discount + delivery).toLocaleString();
}

async function updateCartItem(itemId, qty) {
  if (qty < 1) qty = 1;
  try {
    await api(`/cart/${itemId}`, { method: 'PUT', body: JSON.stringify({ quantity: qty }) });
    if (typeof loadCart === 'function') loadCart();
  } catch (e) { showToast(e.message, 'error'); }
}

async function applyCoupon() {
  const code = document.getElementById('couponCode').value.trim();
  if (!code) return;
  try {
    appliedCoupon = await api('/coupons/validate', { method: 'POST', body: JSON.stringify({ code, subtotal: cartData.subtotal }) });
    document.getElementById('couponMsg').textContent = 'Coupon applied! You save ₹' + appliedCoupon.discount.toFixed(0);
    document.getElementById('couponMsg').className = 'text-success';
    localStorage.setItem('coupon', JSON.stringify({ code: appliedCoupon.code, discount: appliedCoupon.discount }));
    updateSummary();
  } catch (e) { document.getElementById('couponMsg').textContent = e.message; document.getElementById('couponMsg').className = 'text-danger'; appliedCoupon = null; localStorage.removeItem('coupon'); updateSummary(); }
}

async function saveForLater(itemId) {
  try {
    await api(`/cart/save-later/${itemId}`, { method: 'POST' });
    showToast('Saved for later');
    loadCart();
  } catch (e) { showToast(e.message, 'error'); }
}

async function loadSavedItems() {
  try {
    const data = await api('/cart/saved');
    savedItems = data.items || [];
    const section = document.getElementById('savedSection');
    const container = document.getElementById('savedItems');
    if (!savedItems.length) { section.style.display = 'none'; return; }
    section.style.display = '';
    container.innerHTML = savedItems.map(item => `
      <div class="cart-item saved-item">
        <img src="${item.image || '/images/no-image.png'}" alt="${item.name}" onerror="this.style.display='none'">
        <div class="flex-grow-1">
          <h6 class="mb-1"><a href="/product/${btoa(String(item.id)).replace(/[+/=]/g, c => ({'+':'-','/':'_','=':''})[c])}" class="text-decoration-none">${item.name}</a></h6>
          <span class="text-primary fw-bold">₹${(item.unit_price || item.price).toLocaleString()}</span>
        </div>
        <div class="text-end" style="min-width:90px">
          <button class="btn btn-sm btn-outline-primary mb-1" onclick="moveToCart(${item.id})">Move to Cart</button>
          <br><button class="btn btn-link text-danger btn-sm p-0" onclick="removeFromCart(${item.id})"><small>Remove</small></button>
        </div>
      </div>
    `).join('');
  } catch (e) { console.error(e); }
}

async function moveToCart(itemId) {
  try {
    await api(`/cart/move-to-cart/${itemId}`, { method: 'POST' });
    showToast('Moved to cart');
    loadCart();
  } catch (e) { showToast(e.message, 'error'); }
}

document.addEventListener('DOMContentLoaded', loadCart);
</script>

<%- include('partials/footer') %>