<%- include('partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="glass-card p-4">
        <div class="text-center mb-4"><i class="fas fa-truck fa-3x text-primary mb-3"></i><h3 class="fw-bold">Track Your Order</h3></div>
        <form id="trackForm">
          <div class="input-group">
            <input type="text" class="form-control form-control-lg" id="orderNum" placeholder="Enter Order Number (e.g. AQ24010001)" required>
            <button type="submit" class="btn btn-primary">Track</button>
          </div>
        </form>
        <div id="trackResult" class="mt-4"></div>
      </div>
    </div>
  </div>
</div>
<script>
document.getElementById('trackForm').addEventListener('submit', async(e) => {
  e.preventDefault();
  const num = document.getElementById('orderNum').value.trim();
  const result = document.getElementById('trackResult');
  try {
    const data = await api(`/orders/track/${num}`);
    const o = data.order;
    let trackingHtml = '', trackingData = [];
    try {
      const t = await api(`/orders/${o.id}/tracking`);
      trackingData = t.tracking || [];
    } catch(e) {}
    const statusColor = { delivered:'success', cancelled:'danger', confirmed:'info', processing:'warning', dispatched:'primary', pending:'secondary' };
    const statusIcon = { pending:'fa-clock', confirmed:'fa-check-circle', processing:'fa-spinner', dispatched:'fa-truck', delivered:'fa-home', cancelled:'fa-times-circle' };
    if (trackingData.length) {
      trackingHtml = `<div class="mt-3"><h6 class="fw-bold mb-3"><i class="fas fa-history me-2"></i>Tracking Timeline</h6>
        <div class="tracking-timeline">`;
      trackingData.forEach((t, i) => {
        const isLast = i === trackingData.length - 1;
        trackingHtml += `<div class="d-flex mb-3 ${isLast ? '' : ''}">
          <div class="me-3 text-center" style="width:36px;flex-shrink:0">
            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:${isLast ? 'var(--primary,#0d6efd)' : '#e9ecef'};color:${isLast ? '#fff' : '#6c757d'}">
              <i class="fas ${statusIcon[t.status] || 'fa-circle'} fa-sm"></i>
            </div>
            ${!isLast ? '<div style="width:2px;height:40px;background:#e9ecef;margin:4px auto"></div>' : ''}
          </div>
          <div class="${isLast ? 'fw-bold' : ''}" style="padding-top:4px">
            <div>${t.description || t.status}</div>
            <small class="text-muted">${new Date(t.created_at).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</small>
          </div>
        </div>`;
      });
      trackingHtml += `</div></div>`;
    }
    result.innerHTML = `
      <div class="glass-card p-3"><div class="card-body" style="padding:0">
        <h6>Order #${o.order_number}</h6>
        <p class="mb-2">Status: <span class="badge bg-${statusColor[o.order_status] || 'secondary'} fs-6">${o.order_status}</span></p>
        <p class="mb-2">Payment: <span class="badge bg-${o.payment_status==='paid'?'success':'secondary'}">${o.payment_status}</span></p>
        <p class="mb-2">Total: ₹${o.total.toLocaleString()}</p>
        ${trackingHtml}
      </div></div>`;
  } catch(e) { result.innerHTML = '<div class="alert alert-danger">Order not found. Please check the order number.</div>'; }
});
</script>
<%- include('partials/footer') %>